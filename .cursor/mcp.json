{
  "mcpServers": {
    "oak-curriculum-stdio": {
      "type": "stdio",
      "command": "pnpm",
      "args": ["exec", "tsx", "apps/oak-curriculum-mcp-stdio/bin/oak-curriculum-mcp.ts"],
      "env": {
        "LOG_LEVEL": "debug"
      }
    },
    "oak-curriculum-http-remote": {
      "type": "http",
      "url": "https://curriculum-mcp-alpha.oaknational.dev/mcp",
      "headers": {
        "Authorization": "Bearer super-duper-secret-dev-token?!"
      }
    },
    "oak-curriculum-http-remote-unprotected": {
      "type": "http",
      "url": "https://poc-oak-open-curriculum-mcp-git-feat-semanticsearch.vercel.thenational.academy/mcp"
    },
    "oak-curriculum-http-remote-preview": {
      "type": "http",
      "url": "https://poc-oak-open-curriculum-mcp-git-feat-openaiconnectorsupport.vercel.thenational.academy/mcp",
      "headers": {
        "Authorization": "Bearer super-duper-secret-dev-token?!"
      }
    },
    "oak-curriculum-http-local": {
      "type": "http",
      "url": "http://localhost:3333/mcp",
      "headers": {
        "Authorization": "Bearer dev-token"
      }
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    }
  }
}
