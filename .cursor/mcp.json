{
  "mcpServers": {
    "oak-curriculum-stdio": {
      "type": "stdio",
      "command": "pnpm",
      "args": [
        "exec",
        "tsx",
        "apps/oak-curriculum-mcp-stdio/bin/oak-curriculum-mcp.ts"
      ],
      "env": {
        "LOG_LEVEL": "debug"
      }
    },
    "oak-prod": {
      "type": "http",
      "url": "https://curriculum-mcp-alpha.oaknational.dev/mcp"
    },
    "oak-preview": {
      "type": "http",
      "url": "https://poc-oak-open-curriculum-mcp-git-feat-searchqolfixes.vercel.thenational.academy/mcp"
    },
    "oak-local": {
      "type": "http",
      "url": "http://localhost:3333/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ]
    },
    "next-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "next-devtools-mcp@latest"
      ]
    },
    "Vercel": {
      "type": "http",
      "url": "https://mcp.vercel.com",
      "headers": {}
    },
    "Clerk": {
      "url": "https://mcp.clerk.com/mcp",
      "headers": {}
    }
  }
}