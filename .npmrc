# pnpm workspace configuration
# Ensure workspace packages are linked locally during development
link-workspace-packages=deep
prefer-workspace-packages=true

# Publishing configuration
# workspace:^ means "use workspace version during dev, real version during publish"
# workspace:* means "use workspace version during dev, exact version during publish"
# workspace:~ means "use workspace version during dev, patch-compatible version during publish"
save-workspace-protocol=rolling

# Hoist pattern for shared dependencies
shamefully-hoist=true