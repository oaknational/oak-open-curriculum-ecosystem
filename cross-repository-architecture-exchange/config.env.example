# Configuration for cross-repository framework sync
# This file is sourced by sync-gist-gh.sh
# 
# Copy this file to config.env and update with your values
# Note: The script sets GH_PROMPT_DISABLED=true to avoid interactive prompts
# This allows it to be run programmatically without hanging on user input

# GitHub Gist ID for the RFC document
GIST_ID="a gist ID"

# Local filename for the RFC document
LOCAL_FILE="a local rfc file name, we probably don't want this, just synch the whole directory"

# Script filename in the gist
SCRIPT_FILE="sync-gist-gh.sh"

# Gist owner (for URL construction)
GIST_OWNER="a github user name"

# Contributor name for RFC updates
# Update this with your name/identifier
CONTRIBUTOR_NAME="A contributor name"