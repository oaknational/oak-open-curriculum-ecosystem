{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "remoteCache": {
    "enabled": true
  },
  "globalDependencies": ["**/.env.*local", "tsconfig.base.json"],
  "tasks": {
    "type-gen": {
      "dependsOn": ["^type-gen"],
      "cache": true,
      "outputs": ["**/generated/**"],
      "inputs": ["$TURBO_DEFAULT$", "**/type-gen/**/*.ts", "**/scripts/**/*.ts"],
      "env": ["OAK_API_KEY"],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "doc-gen": {
      "dependsOn": ["^doc-gen"],
      "cache": true,
      "outputs": ["**/docs/api/**", "**/docs/api-md/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/type-gen/**/*.ts",
        "**/scripts/**/*.ts",
        "next.config.ts",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": ["dist/**", ".tsup/**", ".next/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "next.config.ts",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ],
      "env": ["OAK_API_KEY"],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["OAK_API_KEY"],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "lint": {
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/eslint.config.base.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "**/*.test.ts",
        "**/*.spec.ts"
      ]
    },
    "test": {
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "tests/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "mutate": {
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "tests/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts",
        "stryker.config.ts",
        "$TURBO_ROOT$/stryker.config.base.ts"
      ]
    },
    "test:e2e": {
      "outputs": [],
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "e2e-tests/**/*.ts",
        "vitest.e2e.config.ts",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport"
      ],
      "env": ["NOTION_API_KEY", "OAK_API_KEY", "LOG_LEVEL"],
      "passThroughEnv": ["NOTION_API_KEY", "LOG_LEVEL", "OAK_API_KEY"]
    },
    "test:ui": {
      "outputs": [],
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "next.config.ts",
        "playwright.config.ts"
      ]
    },
    "type-check": {
      "dependsOn": [],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "**/*.d.ts"
      ]
    },
    "smoke:dev": {
      "dependsOn": ["^smoke:dev"],
      "cache": false,
      "outputs": [],
      "env": ["OAK_API_KEY"],
      "passThroughEnv": ["OAK_API_KEY"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/scripts/smoke-dev.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    }
  }
}
