{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "remoteCache": {
    "enabled": true
  },
  "globalDependencies": ["**/.env.*local", "tsconfig.base.json"],
  "tasks": {
    "build-adapter": {
      "cache": true,
      "outputs": ["dist/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts"
      ]
    },
    "build-linting": {
      "cache": true,
      "outputs": ["dist/**"],
      "inputs": ["$TURBO_DEFAULT$", "src/**/*.ts", "tsconfig.json", "tsup.config.ts"]
    },
    "type-gen": {
      "dependsOn": ["^type-gen", "^build-adapter"],
      "cache": true,
      "outputs": ["**/generated/**"],
      "inputs": ["$TURBO_DEFAULT$", "**/type-gen/**/*.ts", "**/scripts/**/*.ts"],
      "env": ["OAK_API_KEY"],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "doc-gen": {
      "dependsOn": ["^doc-gen", "^build"],
      "cache": true,
      "outputs": ["**/docs/api/**", "**/docs/api-md/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/type-gen/**/*.ts",
        "**/scripts/**/*.ts",
        "next.config.ts",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "build": {
      "dependsOn": ["^build", "type-gen"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**", ".next/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/core/oak-eslint",
        "$TURBO_ROOT$/packages/core/openapi-zod-client-adapter",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "next.config.ts",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ],
      "env": ["OAK_API_KEY"],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["OAK_API_KEY"],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "lint": {
      "dependsOn": ["^build-linting", "type-gen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/eslint.config.base.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/core/oak-eslint",
        "$TURBO_ROOT$/packages/core/openapi-zod-client-adapter",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "smoke-tests/**/*.ts",
        "**/*.test.ts",
        "**/*.spec.ts"
      ]
    },
    "lint:fix": {
      "dependsOn": ["^build-linting", "type-gen"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/eslint.config.base.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/core/oak-eslint",
        "$TURBO_ROOT$/packages/core/openapi-zod-client-adapter",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "smoke-tests/**/*.ts",
        "**/*.test.ts",
        "**/*.spec.ts"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "tests/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "mutate": {
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "tests/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts",
        "stryker.config.ts",
        "$TURBO_ROOT$/stryker.config.base.ts"
      ]
    },
    "test:e2e": {
      "outputs": [],
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "e2e-tests/**/*.ts",
        "vitest.e2e.config.ts",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport"
      ],
      "env": ["NOTION_API_KEY", "OAK_API_KEY", "LOG_LEVEL"],
      "passThroughEnv": ["NOTION_API_KEY", "LOG_LEVEL", "OAK_API_KEY"]
    },
    "test:e2e:built": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        "e2e-tests/built-server.e2e.test.ts",
        "dist/**/*.js",
        "dist/**/*.d.ts"
      ],
      "env": ["OAK_API_KEY", "CLERK_PUBLISHABLE_KEY", "CLERK_SECRET_KEY", "LOG_LEVEL"],
      "passThroughEnv": ["OAK_API_KEY", "CLERK_PUBLISHABLE_KEY", "CLERK_SECRET_KEY", "LOG_LEVEL"]
    },
    "test:ui": {
      "dependsOn": ["type-gen"],
      "outputs": [],
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "tests/**/*.ts",
        "next.config.ts",
        "playwright.config.ts"
      ]
    },
    "type-check": {
      "dependsOn": ["^build", "type-gen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/packages/core/mcp-core",
        "$TURBO_ROOT$/packages/libs/env",
        "$TURBO_ROOT$/packages/libs/logger",
        "$TURBO_ROOT$/packages/libs/storage",
        "$TURBO_ROOT$/packages/libs/transport",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "app/**/*.ts",
        "app/**/*.tsx",
        "smoke-tests/**/*.ts",
        "**/*.d.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts"
      ]
    },
    "smoke:dev:stub": {
      "dependsOn": ["^smoke:dev:stub", "^type-gen"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-stub.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "env": ["LOG_LEVEL"],
      "passThroughEnv": ["LOG_LEVEL"]
    },
    "smoke:dev:live": {
      "dependsOn": ["^smoke:dev:live", "^type-gen"],
      "cache": false,
      "outputs": [],
      "env": ["OAK_API_KEY", "LOG_LEVEL"],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:dev:live:auth": {
      "dependsOn": ["^smoke:dev:live:auth", "^type-gen"],
      "cache": false,
      "outputs": [],
      "env": ["OAK_API_KEY", "LOG_LEVEL"],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live-auth.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:remote": {
      "dependsOn": ["^smoke:remote", "^type-gen"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-remote.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "env": ["LOG_LEVEL"],
      "passThroughEnv": ["LOG_LEVEL"]
    }
  }
}
