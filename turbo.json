{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local", "tsconfig.base.json"],
  "tasks": {
    "type-gen": {
      "dependsOn": ["^type-gen"],
      "cache": true,
      "outputs": ["src/types/generated/**", "src/organa/mcp/generated/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "scripts/**/*.ts",
        "src/chorai/tool-metadata/**"
      ]
    },
    "build": {
      "dependsOn": ["^build", "type-gen"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/ecosystem/moria/moria-mcp",
        "$TURBO_ROOT$/ecosystem/histoi/histos-env",
        "$TURBO_ROOT$/ecosystem/histoi/histos-logger",
        "$TURBO_ROOT$/ecosystem/histoi/histos-storage",
        "$TURBO_ROOT$/ecosystem/histoi/histos-transport",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "format": {
      "outputs": ["**/*.{ts,tsx,js,jsx,json,md}"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "**/*.md",
        "**/*.json",
        ".prettierrc",
        "$TURBO_ROOT$/.prettierrc",
        "$TURBO_ROOT$/prettier.config.js"
      ]
    },
    "format:check": {
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "**/*.md",
        "**/*.json",
        ".prettierrc",
        "$TURBO_ROOT$/.prettierrc",
        "$TURBO_ROOT$/prettier.config.js"
      ]
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/eslint.config.base.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/ecosystem/moria/moria-mcp",
        "$TURBO_ROOT$/ecosystem/histoi/histos-env",
        "$TURBO_ROOT$/ecosystem/histoi/histos-logger",
        "$TURBO_ROOT$/ecosystem/histoi/histos-storage",
        "$TURBO_ROOT$/ecosystem/histoi/histos-transport",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "**/*.test.ts",
        "**/*.spec.ts"
      ]
    },
    "test": {
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "tests/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "test:unit": {
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "tests/**/*.ts",
        "!src/**/*.integration.test.ts",
        "!src/**/*.e2e.test.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "test:integration": {
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/ecosystem/moria/moria-mcp",
        "$TURBO_ROOT$/ecosystem/histoi/histos-env",
        "$TURBO_ROOT$/ecosystem/histoi/histos-logger",
        "$TURBO_ROOT$/ecosystem/histoi/histos-storage",
        "$TURBO_ROOT$/ecosystem/histoi/histos-transport",
        "src/**/*.integration.test.ts",
        "src/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "test:e2e": {
      "outputs": [],
      "cache": false,
      "inputs": [
        "$TURBO_DEFAULT$",
        "e2e-tests/**/*.ts",
        "vitest.e2e.config.ts",
        "$TURBO_ROOT$/ecosystem/moria/moria-mcp",
        "$TURBO_ROOT$/ecosystem/histoi/histos-env",
        "$TURBO_ROOT$/ecosystem/histoi/histos-logger",
        "$TURBO_ROOT$/ecosystem/histoi/histos-storage",
        "$TURBO_ROOT$/ecosystem/histoi/histos-transport"
      ],
      "env": ["NOTION_API_KEY", "RUN_E2E", "LOG_LEVEL"],
      "passThroughEnv": ["RUN_E2E", "NOTION_API_KEY", "LOG_LEVEL"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/ecosystem/moria/moria-mcp",
        "$TURBO_ROOT$/ecosystem/histoi/histos-env",
        "$TURBO_ROOT$/ecosystem/histoi/histos-logger",
        "$TURBO_ROOT$/ecosystem/histoi/histos-storage",
        "$TURBO_ROOT$/ecosystem/histoi/histos-transport",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "**/*.d.ts"
      ]
    }
  }
}
