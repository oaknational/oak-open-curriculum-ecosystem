{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "remoteCache": {
    "enabled": true
  },
  "globalDependencies": ["**/.env.*local", "tsconfig.base.json"],
  "tasks": {
    "sdk-codegen": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["**/generated/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/code-generation/**/*.ts",
        "**/vocab-gen/**/*.ts",
        "**/scripts/**/*.ts",
        "**/schema-cache/**"
      ],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "doc-gen": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["**/docs/api/**", "**/docs/api-md/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/code-generation/**/*.ts",
        "**/scripts/**/*.ts",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "@oaknational/sdk-codegen#build": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "@oaknational/oak-curriculum-mcp-streamable-http#build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts",
        "widget/**/*.ts",
        "widget/**/*.tsx",
        "widget/**/*.css",
        "widget/**/*.html",
        "widget/vite.config.ts",
        "widget/tsconfig.json"
      ]
    },
    "@oaknational/sdk-codegen#test": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "@oaknational/sdk-codegen#type-check": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "@oaknational/sdk-codegen#lint": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "@oaknational/sdk-codegen#lint:fix": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "lint:fix": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "mutate": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts",
        "stryker.config.ts",
        "$TURBO_ROOT$/stryker.config.base.ts"
      ]
    },
    "test:widget": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "widget/**/*.ts",
        "widget/**/*.tsx",
        "vitest.widget.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "e2e-tests/**/*.ts", "vitest.e2e.config.ts"],
      "passThroughEnv": ["LOG_LEVEL", "OAK_API_KEY"]
    },
    "test:ui": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "**/*.ts", "playwright.config.ts"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "smoke:dev:stub": {
      "dependsOn": ["build", "test:e2e"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-stub.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "passThroughEnv": ["LOG_LEVEL"]
    },
    "smoke:dev:live": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:dev:live:auth": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live-auth.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:remote": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-remote.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "passThroughEnv": ["LOG_LEVEL"]
    }
  }
}
