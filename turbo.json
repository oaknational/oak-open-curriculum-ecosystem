{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "remoteCache": {
    "enabled": true
  },
  "globalDependencies": ["**/.env.*local", "tsconfig.base.json"],
  "tasks": {
    "type-gen": {
      "dependsOn": ["^type-gen", "^build"],
      "cache": true,
      "outputs": ["**/generated/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/type-gen/**/*.ts",
        "**/vocab-gen/**/*.ts",
        "**/scripts/**/*.ts",
        "**/schema-cache/**"
      ],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "doc-gen": {
      "dependsOn": ["^doc-gen", "^build", "type-gen"],
      "cache": true,
      "outputs": ["**/docs/api/**", "**/docs/api-md/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/type-gen/**/*.ts",
        "**/scripts/**/*.ts",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "build": {
      "dependsOn": ["^build", "type-gen"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "lint": {
      "dependsOn": ["^build", "build", "type-gen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/eslint.config.base.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "smoke-tests/**/*.ts",
        "**/*.test.ts",
        "**/*.spec.ts"
      ]
    },
    "lint:fix": {
      "dependsOn": ["^build", "build", "type-gen"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/eslint.config.base.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "tests/**/*.ts",
        "smoke-tests/**/*.ts",
        "**/*.test.ts",
        "**/*.spec.ts"
      ]
    },
    "test": {
      "dependsOn": ["^build", "type-gen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "tests/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "mutate": {
      "dependsOn": ["^build", "type-gen"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "tests/**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts",
        "stryker.config.ts",
        "$TURBO_ROOT$/stryker.config.base.ts"
      ]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "e2e-tests/**/*.ts", "vitest.config.e2e.ts"],
      "passThroughEnv": ["LOG_LEVEL", "OAK_API_KEY"]
    },
    "test:ui": {
      "dependsOn": ["^build", "build", "type-gen"],
      "outputs": [],
      "cache": true,
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "tests/**/*.ts",
        "playwright.config.ts"
      ]
    },
    "type-check": {
      "dependsOn": ["^build", "type-gen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "smoke-tests/**/*.ts",
        "**/*.d.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts"
      ]
    },
    "smoke:dev:stub": {
      "dependsOn": ["^smoke:dev:stub", "^build", "test:e2e"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-stub.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "passThroughEnv": ["LOG_LEVEL"]
    },
    "smoke:dev:live": {
      "dependsOn": ["^smoke:dev:live", "^build", "build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:dev:live:auth": {
      "dependsOn": ["^smoke:dev:live:auth", "^build", "build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live-auth.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:remote": {
      "dependsOn": ["^smoke:remote", "^build", "build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-remote.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "passThroughEnv": ["LOG_LEVEL"]
    }
  }
}
