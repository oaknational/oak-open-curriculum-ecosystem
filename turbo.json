{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "remoteCache": {
    "enabled": true
  },
  "globalPassThroughEnv": [
    "OAK_API_KEY",
    "LOG_LEVEL",
    "OAK_API_URL",
    "CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "DANGEROUSLY_DISABLE_AUTH",
    "ELASTICSEARCH_URL",
    "ELASTICSEARCH_API_KEY",
    "SENTRY_AUTH_TOKEN",
    "SENTRY_DSN",
    "SENTRY_MODE",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_REPO_SLUG",
    "SENTRY_TRACES_SAMPLE_RATE",
    "VERCEL_GIT_REPO_OWNER",
    "VERCEL_GIT_REPO_SLUG"
  ],
  "globalDependencies": ["**/.env.*local", "tsconfig.base.json"],
  "tasks": {
    "sdk-codegen": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["**/generated/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/code-generation/**/*.ts",
        "**/vocab-gen/**/*.ts",
        "**/scripts/**/*.ts",
        "**/schema-cache/**"
      ],
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "doc-gen": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["**/docs/api/**", "**/docs/api-md/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/code-generation/**/*.ts",
        "**/scripts/**/*.ts",
        "src/**/*.ts",
        "src/types/generated/**/*.ts",
        "src/types/generated/**/*.d.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsup.config.base.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "@oaknational/sdk-codegen#build": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsup.config.base.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "@oaknational/oak-curriculum-mcp-streamable-http#build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["dist/**", ".tsup/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "$TURBO_ROOT$/tsup.config.base.ts",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsup.config.ts",
        "src/**/*.ts",
        "!src/**/*.test.ts",
        "!src/**/*.spec.ts"
      ]
    },
    "@oaknational/oak-design-tokens#build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["dist/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "src/**/*.json"
      ]
    },
    "@oaknational/oak-design-tokens#test": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "src/**/*.ts",
        "src/**/*.json",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "@oaknational/oak-design-tokens#type-check": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "src/**/*.json"
      ]
    },
    "@oaknational/oak-design-tokens#lint": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "src/**/*.json"
      ]
    },
    "@oaknational/oak-design-tokens#lint:fix": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "src/**/*.ts",
        "src/**/*.json"
      ]
    },
    "@oaknational/sdk-codegen#test": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "@oaknational/sdk-codegen#type-check": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "@oaknational/sdk-codegen#lint": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "@oaknational/sdk-codegen#lint:fix": {
      "dependsOn": ["^build", "sdk-codegen"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "passThroughEnv": ["OAK_API_KEY"]
    },
    "dev:widget": {
      "cache": false,
      "persistent": true
    },
    "dev:widget-in-host": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "lint:fix": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/eslint.config.ts",
        "$TURBO_ROOT$/tsconfig.base.json",
        "eslint.config.ts",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "mutate": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "**/*.ts",
        "vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts",
        "stryker.config.ts",
        "$TURBO_ROOT$/stryker.config.base.ts"
      ]
    },
    "test:widget": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "widget/**/*.ts",
        "widget/**/*.tsx",
        "vitest.widget.config.ts",
        "$TURBO_ROOT$/vitest.config.base.ts"
      ]
    },
    "test:e2e": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "e2e-tests/**/*.ts", "vitest.e2e.config.ts"],
      "passThroughEnv": ["LOG_LEVEL", "OAK_API_KEY"]
    },
    "test:ui": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "**/*.ts", "playwright.config.ts"]
    },
    "test:a11y": {
      "dependsOn": ["build", "test:ui"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "**/*.ts", "playwright.config.ts"]
    },
    "test:widget:ui": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "**/*.ts", "**/*.tsx", "playwright.widget.config.ts"]
    },
    "test:widget:a11y": {
      "dependsOn": ["build", "test:widget:ui"],
      "outputs": [],
      "cache": true,
      "inputs": ["$TURBO_DEFAULT$", "**/*.ts", "**/*.tsx", "playwright.widget.config.ts"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "$TURBO_ROOT$/tsconfig.base.json",
        "tsconfig.json",
        "tsconfig.build.json",
        "tsconfig.lint.json",
        "**/*.ts"
      ]
    },
    "smoke:dev:stub": {
      "dependsOn": ["build", "test:e2e"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-stub.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "passThroughEnv": ["LOG_LEVEL"]
    },
    "smoke:dev:live": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:dev:live:auth": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": [],
      "passThroughEnv": ["OAK_API_KEY", "LOG_LEVEL"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-dev-live-auth.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ]
    },
    "smoke:remote": {
      "dependsOn": ["build"],
      "cache": false,
      "outputs": [],
      "inputs": [
        "$TURBO_DEFAULT$",
        "apps/oak-curriculum-mcp-streamable-http/smoke-tests/smoke-remote.ts",
        "apps/oak-curriculum-mcp-streamable-http/src/**/*.ts"
      ],
      "passThroughEnv": ["LOG_LEVEL"]
    }
  }
}
