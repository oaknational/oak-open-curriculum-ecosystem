{
  "compilerOptions": {
    "erasableSyntaxOnly": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022"],
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "customConditions": ["development"],
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "paths": {
      "@oaknational/oak-notion-mcp": ["./apps/oak-notion-mcp/src"],
      "@oaknational/oak-notion-mcp/*": ["./apps/oak-notion-mcp/src/*"],
      "@oaknational/oak-curriculum-mcp": ["./apps/oak-curriculum-mcp/src"],
      "@oaknational/oak-curriculum-mcp/*": ["./apps/oak-curriculum-mcp/src/*"],
      "@oaknational/oak-curriculum-sdk": ["./packages/sdks/oak-curriculum-sdk/src"],
      "@oaknational/oak-curriculum-sdk/*": ["./packages/sdks/oak-curriculum-sdk/src/*"],
      "@oaknational/mcp-core": ["./packages/core/mcp-core/src"],
      "@oaknational/mcp-core/*": ["./packages/core/mcp-core/src/*"],
      "@oaknational/mcp-env": ["./packages/libs/env/src"],
      "@oaknational/mcp-env/*": ["./packages/libs/env/src/*"],
      "@oaknational/mcp-logger": ["./packages/libs/logger/src"],
      "@oaknational/mcp-logger/*": ["./packages/libs/logger/src/*"],
      "@oaknational/mcp-storage": ["./packages/libs/storage/src"],
      "@oaknational/mcp-storage/*": ["./packages/libs/storage/src/*"],
      "@oaknational/mcp-transport": ["./packages/libs/transport/src"],
      "@oaknational/mcp-transport/*": ["./packages/libs/transport/src/*"],
      "@oaknational/mcp-providers-node": ["./packages/providers/mcp-providers-node/src"],
      "@oaknational/mcp-providers-node/*": ["./packages/providers/mcp-providers-node/src/*"]
    }
  }
}
