{
  "name": "@oaknational/agent-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript tooling workspace for agent operational CLIs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/src/bin/*.js dist/src/claude/statusline-identity.js",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "smoke:collaboration-tui": "tsx smoke-tests/collaboration-tui-start.smoke.ts",
    "type-check": "tsc -p tsconfig.json",
    "agent-tools": "cd .. && node agent-tools/dist/src/bin/agent-tools.js",
    "agent-identity": "cd .. && node agent-tools/dist/src/bin/agent-tools.js agent-identity",
    "collaboration-state": "cd .. && node agent-tools/dist/src/bin/agent-tools.js collaboration-state",
    "practice-substrate": "pnpm -s build && cd .. && node agent-tools/dist/src/bin/practice-substrate.js",
    "branch-touched-files": "cd .. && node agent-tools/dist/src/bin/agent-tools.js branch-touched-files",
    "context-cost": "cd .. && node agent-tools/dist/src/bin/agent-tools.js context-cost",
    "codex-session-identity-hook": "pnpm -s build && node dist/src/bin/codex-session-identity-hook.js",
    "claude-agent-ops": "tsx src/bin/claude-agent-ops.ts",
    "commit-queue": "cd .. && node agent-tools/dist/src/bin/agent-tools.js commit-queue",
    "codex-exec": "cd .. && node agent-tools/dist/src/bin/agent-tools.js codex-exec",
    "cursor-session-from-claude-session": "tsx src/bin/cursor-session-from-claude-session.ts",
    "codex-reviewer-resolve": "tsx src/bin/codex-reviewer-resolve.ts",
    "skills-adapter-generate": "tsx src/bin/skills-adapter-generate.ts",
    "repo-check": "cd .. && pnpm exec tsx agent-tools/scripts/repo-check.ts",
    "check-blocked-patterns": "cd .. && pnpm exec tsx agent-tools/scripts/check-blocked-patterns.ts",
    "check-blocked-content": "cd .. && pnpm exec tsx agent-tools/src/hook-policy/check-blocked-content.ts",
    "check-commit-message": "cd .. && bash agent-tools/scripts/check-commit-message.sh",
    "check-commit-skill-advisories": "cd .. && pnpm exec tsx agent-tools/scripts/check-commit-skill-advisories.ts",
    "prevent-accidental-major-version": "cd .. && pnpm exec tsx agent-tools/scripts/prevent-accidental-major-version.ts",
    "validate-fitness-vocabulary": "cd .. && pnpm exec tsx agent-tools/scripts/validate-fitness-vocabulary.ts",
    "validate-no-stale-script-invocations": "cd .. && pnpm exec tsx agent-tools/scripts/validate-no-stale-script-invocations.ts",
    "validate-portability": "cd .. && pnpm exec tsx agent-tools/scripts/validate-portability.ts",
    "validate-portability:fix": "cd .. && pnpm exec tsx agent-tools/scripts/validate-portability.ts --fix",
    "validate-practice-fitness": "cd .. && pnpm exec tsx agent-tools/scripts/validate-practice-fitness.ts",
    "validate-subagents": "cd .. && pnpm exec tsx agent-tools/scripts/validate-subagents.ts",
    "ci-schema-drift-check": "cd .. && pnpm exec tsx agent-tools/scripts/ci-schema-drift-check.ts",
    "ci-turbo-report": "cd .. && pnpm exec tsx agent-tools/scripts/ci-turbo-report.ts"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.22.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ink": "^7.0.4",
    "react": "^19.2.6",
    "tinyglobby": "^0.2.16",
    "typescript": "^6.0.3",
    "uuid": "^14.0.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  }
}
