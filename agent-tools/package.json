{
  "name": "@oaknational/agent-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TypeScript tooling workspace for agent operational CLIs",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/src/bin/*.js dist/src/claude/statusline-identity.js",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "type-check": "tsc -p tsconfig.json",
    "agent-identity": "pnpm -s build && node dist/src/bin/agent-identity.js",
    "collaboration-state": "pnpm -s build && cd .. && node agent-tools/dist/src/bin/collaboration-state.js",
    "claude-agent-ops": "tsx src/bin/claude-agent-ops.ts",
    "commit-queue": "pnpm -s build && node dist/src/bin/commit-queue.js",
    "cursor-session-from-claude-session": "tsx src/bin/cursor-session-from-claude-session.ts",
    "codex-reviewer-resolve": "tsx src/bin/codex-reviewer-resolve.ts"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.3"
  }
}
