{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "."
  },
  "include": [
    "ecosystem/**/src/**/*.ts",
    "ecosystem/**/tests/**/*.ts",
    "ecosystem/**/**.test.ts",
    "ecosystem/**/**.spec.ts",
    "packages/**/src/**/*.ts",
    "packages/**/tests/**/*.ts",
    "packages/**/**.test.ts",
    "packages/**/**.spec.ts"
  ],
  "exclude": [
    "**/dist/**",
    "**/coverage/**",
    "node_modules"
  ]
}
