{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": "."
  },
  "include": [
    "apps/**/src/**/*.ts",
    "apps/**/tests/**/*.ts",
    "apps/**/**.test.ts",
    "apps/**/**.spec.ts",
    "apps/**/bin/**/*.ts",
    "ecosystem/**/src/**/*.ts",
    "ecosystem/**/tests/**/*.ts",
    "ecosystem/**/**.test.ts",
    "ecosystem/**/**.spec.ts",
    "ecosystem/**/bin/**/*.ts",
    "packages/**/src/**/*.ts",
    "packages/**/scripts/**/*.ts",
    "packages/**/tests/**/*.ts",
    "packages/**/**.test.ts",
    "packages/**/**.spec.ts"
  ],
  "exclude": ["apps/**/dist/**", "**/dist/**", "**/coverage/**", "node_modules"]
}
