{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/lib/elastic-http.ts",
    "src/lib/hybrid-search/sequence-facets.ts",
    "src/lib/hybrid-search/sequences.ts",
    "src/lib/hybrid-search/types.ts",
    "src/lib/openapi.schemas.ts",
    "src/adapters/oak-adapter.ts",
    "src/adapters/oak-adapter-types.ts",
    "src/adapters/sdk-guards.ts"
  ],
  "out": "docs/api",
  "tsconfig": "./tsconfig.json",
  "readme": "none",
  "githubPages": false,
  "categorizeByGroup": true,
  "sort": ["kind", "instance-first", "alphabetical"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "e2e-tests/**", "scripts/**"],
  "excludeInternal": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "includeVersion": true,

  "treatValidationWarningsAsErrors": true
}
