{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": [
    "src/lib/hybrid-search/index.ts",
    "src/lib/hybrid-search/lessons.ts",
    "src/lib/hybrid-search/units.ts",
    "src/lib/hybrid-search/types.ts",
    "src/lib/openapi.ts",
    "src/lib/openapi.register.ts",
    "src/adapters/oak-adapter-sdk.ts",
    "src/adapters/oak-adapter-sdk-types.ts",
    "src/adapters/sdk-guards.ts"
  ],
  "out": "docs/api",
  "tsconfig": "./tsconfig.json",
  "readme": "none",
  "githubPages": false,
  "categorizeByGroup": true,
  "sort": ["kind", "instance-first", "alphabetical"],
  "exclude": ["**/*.test.ts", "**/*.spec.ts", "app/**", "e2e-tests/**", "public/**", "scripts/**"],
  "excludeInternal": true,
  "excludePrivate": true,
  "excludeProtected": false,
  "includeVersion": true,

  "treatValidationWarningsAsErrors": true
}
