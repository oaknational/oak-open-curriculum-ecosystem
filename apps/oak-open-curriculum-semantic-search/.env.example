# =============================================================================
# Elasticsearch Serverless Configuration
# =============================================================================
# Used by: ES client, setup CLI (pnpm es:setup), ingestion scripts
#
# To provision ES Serverless:
# 1. Create account at https://cloud.elastic.co/
# 2. Create a Serverless project (Search type)
# 3. Generate API key with manage + search privileges
# 4. Copy the endpoint URL and API key below
#
# See: .agent/plans/semantic-search/semantic-search-overview.md Phase 0
# =============================================================================

ELASTICSEARCH_URL=https://your-elasticsearch-url-here
ELASTICSEARCH_API_KEY=your_elasticsearch_api_key_here

# =============================================================================
# Oak Curriculum SDK Configuration
# =============================================================================
# Used by: SDK ingestion scripts, Next.js API routes (live data mode)

OAK_API_KEY=your_oak_api_key_here

# =============================================================================
# Search Service Configuration
# =============================================================================
# Used by: Next.js app routes


# Shared secret for admin/status routes (must be ≥10 chars)
SEARCH_API_KEY=your_search_api_key_here

# Index namespace: primary | sandbox
SEARCH_INDEX_TARGET=primary

# =============================================================================
# Observability Configuration
# =============================================================================
# Used by: All components (ES client, Next.js, CLI scripts)

# Logging level: trace | debug | info | warn | error
LOG_LEVEL=info

# Zero-hit telemetry webhook URL (use 'none' to disable)
ZERO_HIT_WEBHOOK_URL=none

# Enable zero-hit persistence to Elasticsearch index
ZERO_HIT_PERSISTENCE_ENABLED=false

# Retention period for zero-hit events (days, 7-365)
ZERO_HIT_INDEX_RETENTION_DAYS=30

# =============================================================================
# Development Configuration (Next.js)
# =============================================================================
# Used by: Next.js client-side code and API routes

# Dev server port (defaults to 3003 to avoid conflicts with other Next.js apps)
SEMANTIC_SEARCH_PORT=3003

# Set to true to enable logging of web vitals in the browser console
NEXT_PUBLIC_WEB_VITALS_LOGGING=true

# Controls visibility of the search fixture toggle in the UI (defaults to true)
NEXT_PUBLIC_ENABLE_FIXTURE_TOGGLE=true

# Data source mode: fixtures | fixtures-empty | fixtures-error | live
# Set to 'live' to use real ES data, 'fixtures' for development with mock data
SEMANTIC_SEARCH_USE_FIXTURES=fixtures

# =============================================================================
# SDK Response Caching (Development)
# =============================================================================
# Used by: Ingestion CLI (pnpm es:ingest-live)
# Requires: Redis running (docker compose up -d)
# See: docs/SDK-CACHING.md for full documentation

# Enable SDK response caching (default: false)
# When enabled, API responses are cached in Redis to speed up repeated ingestion runs
SDK_CACHE_ENABLED=false

# Redis connection URL (default: redis://localhost:6379)
SDK_CACHE_REDIS_URL=redis://localhost:6379

# Cache TTL in days (default: 14)
# Cached responses expire after this period
SDK_CACHE_TTL_DAYS=14

# =============================================================================
# AI Provider Configuration (Natural Language Search) - For building NL search into the app, nothing to do with the search service itself.
# =============================================================================
# Used by: Next.js NL search API (/api/search/nl)

# AI provider: openai | none (set to 'none' to disable NL search)
AI_PROVIDER=openai

# Required when AI_PROVIDER=openai (must be ≥10 chars)
OPENAI_API_KEY=your_openai_api_key_here