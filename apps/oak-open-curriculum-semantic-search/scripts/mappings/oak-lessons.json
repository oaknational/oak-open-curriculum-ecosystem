{
  "settings": {
    "analysis": {
      "filter": {
        "oak_syns_filter": {
          "type": "synonym_graph",
          "synonyms_set": "oak-syns",
          "updateable": true
        }
      },
      "analyzer": {
        "oak_text": {
          "type": "custom",
          "tokenizer": "standard",
          "filter": ["lowercase", "oak_syns_filter"]
        }
      }
    }
  },
  "mappings": {
    "dynamic": "strict",
    "properties": {
      "lesson_id": { "type": "keyword" },
      "lesson_slug": { "type": "keyword" },
      "lesson_title": {
        "type": "text",
        "analyzer": "oak_text",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } }
      },
      "subject_slug": { "type": "keyword" },
      "key_stage": { "type": "keyword" },
      "year": { "type": "integer" },
      "unit_ids": { "type": "keyword" },
      "unit_titles": {
        "type": "text",
        "analyzer": "oak_text",
        "fields": { "keyword": { "type": "keyword", "ignore_above": 256 } }
      },
      "transcript_text": {
        "type": "text",
        "analyzer": "oak_text",
        "term_vector": "with_positions_offsets"
      },
      "lesson_semantic": { "type": "semantic_text" }
    }
  }
}
