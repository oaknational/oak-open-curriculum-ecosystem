{
  "name": "@oaknational/open-curriculum-semantic-search",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "tsc -p tsconfig.lint.json --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "NODE_OPTIONS='--max-old-space-size=6144' vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:smoke": "vitest run --config vitest.smoke.config.ts",
    "test:watch": "vitest",
    "bulk:download": "tsx scripts/download-bulk.ts",
    "es:setup": "tsx src/lib/elasticsearch/setup/cli.ts setup",
    "es:reset": "tsx src/lib/elasticsearch/setup/cli.ts setup --reset",
    "es:status": "tsx src/lib/elasticsearch/setup/cli.ts status",
    "es:ingest-live": "tsx src/lib/elasticsearch/setup/ingest-live.ts",
    "diagnose:elser": "tsx scripts/diagnose-elser-failures.ts",
    "analyze:elser": "tsx scripts/analyze-elser-failures.ts",
    "ingest:verify": "tsx operations/ingestion/verify-ingestion.ts",
    "benchmark": "tsx evaluation/analysis/benchmark.ts",
    "benchmark:lessons": "tsx evaluation/analysis/benchmark-lessons.ts",
    "benchmark:units": "tsx evaluation/analysis/benchmark-units.ts",
    "benchmark:threads": "tsx evaluation/analysis/benchmark-threads.ts",
    "benchmark:sequences": "tsx evaluation/analysis/benchmark-sequences.ts",
    "bulk:typegen": "tsx ground-truths/generation/generate-ground-truth-types.ts",
    "ground-truth:validate": "tsx evaluation/validation/validate-ground-truth.ts",
    "redis:up": "docker compose up -d",
    "redis:down": "docker compose down",
    "redis:reset": "docker compose down -v",
    "redis:status": "docker compose ps",
    "cache:reset-ttls": "tsx src/adapters/sdk-cache/reset-ttls.ts",
    "elastic:alias-swap": "bash operations/infrastructure/alias-swap.sh",
    "sandbox:ingest": "tsx operations/sandbox/ingest.ts",
    "zero-hit:purge": "tsx operations/observability/delete-zero-hit-events.ts",
    "docs:api:html": "typedoc --options typedoc.json",
    "docs:api:json": "typedoc --options typedoc.json --json docs/api/typedoc.json",
    "docs:verify": "node -e \"const fs=require('node:fs'); const ok = fs.existsSync('docs/api/typedoc.json'); if(!ok){console.error('typedoc.json missing'); process.exit(1)}; console.log('Docs OK')\"",
    "doc-gen": "pnpm -s docs:api:html && pnpm -s docs:api:json && pnpm -s docs:verify"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.2.0",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "@oaknational/result": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.2.0",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/unzipper": "^0.10.11",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "unzipper": "^0.12.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15"
  }
}
