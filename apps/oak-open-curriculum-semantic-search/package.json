{
  "name": "@oaknational/open-curriculum-semantic-search",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev --port ${SEMANTIC_SEARCH_PORT:-3003}",
    "build": "next build",
    "clean": "rm -rf dist .turbo .next",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "test:ui": "playwright test",
    "test:watch": "vitest",
    "es:setup": "tsx src/lib/elasticsearch/setup/cli.ts setup",
    "es:status": "tsx src/lib/elasticsearch/setup/cli.ts status",
    "es:ingest-live": "tsx src/lib/elasticsearch/setup/ingest-live.ts",
    "redis:up": "docker compose up -d",
    "redis:down": "docker compose down",
    "redis:reset": "docker compose down -v",
    "redis:status": "docker compose ps",
    "elastic:alias-swap": "bash scripts/alias-swap.sh",
    "sandbox:ingest": "tsx scripts/sandbox/ingest.ts",
    "zero-hit:purge": "tsx scripts/observability/delete-zero-hit-events.ts",
    "docs:api:html": "typedoc --options typedoc.json",
    "docs:api:json": "typedoc --options typedoc.json --json docs/api/typedoc.json",
    "docs:verify": "node -e \"const fs=require('node:fs'); const ok = fs.existsSync('docs/api/typedoc.json'); if(!ok){console.error('typedoc.json missing'); process.exit(1)}; console.log('Docs OK')\"",
    "doc-gen": "pnpm -s docs:api:html && pnpm -s docs:api:json && pnpm -s docs:verify"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.76",
    "@elastic/elasticsearch": "^9.2.0",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/oak-components": "^1.167.0",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "ai": "^5.0.106",
    "csstype": "^3.2.3",
    "next": "16.0.7",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "redoc": "^2.5.2",
    "styled-components": "^6.1.19",
    "zod": "^4.1.13",
    "dotenv": "^17.2.3",
    "ioredis": "^5.6.1"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@axe-core/playwright": "^4.11.0",
    "@eslint/eslintrc": "^3.3.3",
    "@next/eslint-plugin-next": "16.0.7",
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "jsdom": "^27.2.0",
    "prettier": "^3.7.4",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.15"
  }
}
