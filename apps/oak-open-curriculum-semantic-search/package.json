{
  "name": "@oaknational/open-curriculum-semantic-search",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "clean": "rm -rf dist .turbo .next",
    "start": "next start",
    "lint": "eslint  .",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "test:ui": "playwright test",
    "test:watch": "vitest",
    "elastic:setup": "bash scripts/setup.sh",
    "elastic:alias-swap": "bash scripts/alias-swap.sh",
    "sandbox:ingest": "tsx scripts/sandbox/ingest.ts",
    "zero-hit:purge": "tsx scripts/observability/delete-zero-hit-events.ts",
    "docs:api:html": "typedoc --options typedoc.json",
    "docs:api:json": "typedoc --options typedoc.json --json docs/api/typedoc.json",
    "docs:verify": "node -e \"const fs=require('node:fs'); const ok = fs.existsSync('docs/api/typedoc.json'); if(!ok){console.error('typedoc.json missing'); process.exit(1)}; console.log('Docs OK')\"",
    "doc-gen": "pnpm -s docs:api:html && pnpm -s docs:api:json && pnpm -s docs:verify"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.24",
    "@elastic/elasticsearch": "^9.1.1",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/oak-components": "^1.143.0",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "ai": "^5.0.51",
    "next": "16.0.1",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "redoc": "^2.5.0",
    "styled-components": "^6.1.19",
    "zod": "^4"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.1.0",
    "@axe-core/playwright": "^4.10.2",
    "@eslint/eslintrc": "^3.2.0",
    "@next/eslint-plugin-next": "16.0.1",
    "@playwright/test": "^1.56.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "@vitejs/plugin-react": "^5.0.2",
    "@vitest/ui": "^4.0.12",
    "eslint": "^9.35.0",
    "eslint-config-next": "16.0.1",
    "jsdom": "^25.0.1",
    "prettier": "^3.6.2",
    "typedoc": "^0.28.12",
    "typedoc-plugin-markdown": "^4.4.2",
    "typescript": "^5.9.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.12"
  }
}
