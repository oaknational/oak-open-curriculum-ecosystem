{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "react",
    "noEmit": true,
    "incremental": true,
    "paths": {
      "@/*": ["./*"],
      "@oaknational/oak-curriculum-sdk": ["../../packages/sdks/oak-curriculum-sdk"],
      "@oaknational/oak-curriculum-sdk/*": ["../../packages/sdks/oak-curriculum-sdk/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "allowJs": true,
    "isolatedModules": true
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", "styled.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
