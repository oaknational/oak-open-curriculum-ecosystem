# =============================================================================
# Oak Curriculum MCP Streamable HTTP Server — Environment Variables
# =============================================================================
# Copy to .env.local and fill in your values.
# Loading order (highest precedence last):
#   repo root .env < repo root .env.local < this dir .env < this dir .env.local < process.env
# See: src/runtime-config.ts, ADR-116

# =============================================================================
# Oak Curriculum API
# =============================================================================
OAK_API_KEY=your_oak_api_key_here

# =============================================================================
# Clerk Authentication
# =============================================================================
# Required unless DANGEROUSLY_DISABLE_AUTH=true.
# Get these from: https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Completely disables auth (local development only, never in production)
# DANGEROUSLY_DISABLE_AUTH=true

# =============================================================================
# Elasticsearch
# =============================================================================
# Required for search features and some MCP tool modes.
ELASTICSEARCH_URL=https://your-elasticsearch-url-here
ELASTICSEARCH_API_KEY=your_elasticsearch_api_key_here

# =============================================================================
# Sentry + OpenTelemetry Observability
# =============================================================================
# Three modes:
#   off     — no Sentry (default, safe for local dev)
#   fixture — in-memory capture for tests, no network calls
#   sentry  — live error capture + tracing (requires DSN + sample rate)
SENTRY_MODE=off

# Required when SENTRY_MODE=sentry:
# SENTRY_DSN=https://public@your-org.ingest.sentry.io/http-project-id
# SENTRY_TRACES_SAMPLE_RATE=1.0

# Optional overrides only:
# SENTRY_ENVIRONMENT_OVERRIDE=production
# SENTRY_RELEASE_OVERRIDE=your-release-identifier
# APP_VERSION_OVERRIDE=1.5.0
# GIT_SHA_OVERRIDE=3ad6f452abc123def4567890abc123def4567890
#
# Default metadata behaviour:
# - environment: SENTRY_ENVIRONMENT_OVERRIDE -> VERCEL_ENV -> development
# - release: SENTRY_RELEASE_OVERRIDE -> root package.json version
# - git SHA metadata: GIT_SHA_OVERRIDE -> VERCEL_GIT_COMMIT_SHA
#
# The root package.json version is the canonical application version and is
# updated by the GitHub release workflow, not on every main commit.
#
# Optional Sentry SDK flags:
# SENTRY_ENABLE_LOGS=true
# SENTRY_DEBUG=false

# Sentry CLI token
SENTRY_AUTH_TOKEN=your-sentry-auth-token-here

# =============================================================================
# Server
# =============================================================================
# PORT=3333
LOG_LEVEL=info

# DNS rebinding protection — auto-includes localhost.
# On Vercel, deployment URLs are added automatically.
# ALLOWED_HOSTS=localhost,127.0.0.1

# MCP transport mode: stateless (default, recommended for Vercel) or session
# REMOTE_MCP_MODE=stateless


# Shared secret that gates the diagnostic `/test-error` route.
# When set in `preview` or `development` environments, registers
# `POST /test-error` for repeatable Sentry capture validation
# (handled / unhandled / rejected modes). Forbidden in
# production — `superRefine` below makes that a hard startup
# failure.
#
# Minimum 16 chars to discourage trivial brute-force; rate-
# limited at the route level via the existing `oauthRateLimiter`
# (30 req / 15 min / IP).
TEST_ERROR_SECRET=your-test-error-secret-here
