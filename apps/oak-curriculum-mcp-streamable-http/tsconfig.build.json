{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.unit.test.ts",
    "src/**/*.e2e.test.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "e2e-tests/**/*",
    "vitest.e2e.config.ts",
    "smoke-tests/**/*",
    "docs/**/*",
    "temp-secrets/**/*"
  ]
}
