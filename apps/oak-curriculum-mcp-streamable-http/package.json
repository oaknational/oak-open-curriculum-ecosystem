{
  "name": "@oaknational/oak-curriculum-mcp-streamable-http",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "LOG_LEVEL=debug DANGEROUSLY_DISABLE_AUTH=false ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts",
    "dev:auth": "LOG_LEVEL=debug DANGEROUSLY_DISABLE_AUTH=false ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts",
    "dev:auth:stub": "LOG_LEVEL=debug OAK_CURRICULUM_MCP_USE_STUB_TOOLS=true OAK_API_KEY=stub-api-key DANGEROUSLY_DISABLE_AUTH=false ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts",
    "dev:observe": "LOG_LEVEL=debug DANGEROUSLY_DISABLE_AUTH=false ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts 2>&1 | tee .logs/http-dev-$(date +%Y%m%d-%H%M%S).log",
    "dev:observe:noauth": "LOG_LEVEL=debug DANGEROUSLY_DISABLE_AUTH=true ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts 2>&1 | tee .logs/http-dev-noauth-$(date +%Y%m%d-%H%M%S).log",
    "inspect:oauth": "tsx smoke-tests/smoke-oauth-mcp-inspector.ts",
    "trace:oauth": "tsx smoke-tests/auth/capture-browser-trace.ts",
    "widget:preview": "tsx scripts/widget-preview-server.ts",
    "start": "node dist/src/index.js",
    "prod:harness": "node scripts/server-harness.js",
    "prod:requests": "node scripts/run-requests.js",
    "prod:diagnostics": "pnpm build && pnpm prod:harness",
    "smoke:dev:stub": "tsx smoke-tests/smoke-dev-stub.ts",
    "smoke:dev:live": "tsx smoke-tests/smoke-dev-live.ts",
    "smoke:dev:live:auth": "tsx smoke-tests/smoke-dev-live-auth.ts",
    "smoke:oauth-inspector": "tsx smoke-tests/smoke-oauth-mcp-inspector.ts",
    "smoke:oauth-curl": "./smoke-tests/OAUTH-CURL-TESTS.sh",
    "smoke:oauth:spec": "tsx smoke-tests/smoke-oauth-spec.ts",
    "smoke:remote": "tsx smoke-tests/smoke-remote.ts",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:ui": "playwright test"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.3",
    "@clerk/express": "^2.0.7",
    "@clerk/mcp-tools": "~0.3.1",
    "@elastic/elasticsearch": "^9.3.4",
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@oaknational/curriculum-sdk": "workspace:*",
    "@oaknational/env": "workspace:*",
    "@oaknational/env-resolution": "workspace:*",
    "@oaknational/logger": "workspace:*",
    "@oaknational/oak-search-sdk": "workspace:*",
    "@oaknational/observability": "workspace:*",
    "@oaknational/result": "workspace:*",
    "@oaknational/sdk-codegen": "workspace:*",
    "@oaknational/sentry-mcp": "workspace:*",
    "@oaknational/sentry-node": "workspace:*",
    "@oaknational/type-helpers": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "commander": "^14.0.3",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-list-routes": "^1.3.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.1.0",
    "node-mocks-http": "^1.17.2",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": "24.x"
  },
  "description": "OAuth-enabled MCP server over HTTP for the Oak National Academy Curriculum API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git",
    "directory": "apps/oak-curriculum-mcp-streamable-http"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem/tree/main/apps/oak-curriculum-mcp-streamable-http#readme",
  "keywords": [
    "mcp",
    "oauth",
    "http",
    "oak",
    "curriculum",
    "education"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
