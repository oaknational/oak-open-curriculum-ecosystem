{
  "name": "@oaknational/oak-curriculum-mcp-streamable-http",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "node ../../scripts/validate-root-application-version.mjs && tsx esbuild.config.ts",
    "build:widget": "vite build --config widget/vite.config.ts && node scripts/embed-widget-html.js",
    "clean": "rm -rf dist .turbo .widget-build",
    "dev": "tsx operations/development/http-dev.ts dev",
    "dev:auth": "tsx operations/development/http-dev.ts dev",
    "dev:auth:stub": "OAK_CURRICULUM_MCP_USE_STUB_TOOLS=true OAK_API_KEY=stub-api-key tsx operations/development/http-dev.ts dev",
    "dev:observe": "tsx operations/development/http-dev.ts observe",
    "dev:observe:noauth": "tsx operations/development/http-dev.ts observe-noauth",
    "dev:widget": "PORT=5173; PID=$(lsof -ti :$PORT 2>/dev/null); if [ -n \"$PID\" ]; then NAME=$(ps -p $PID -o comm= 2>/dev/null); echo \"Port $PORT blocked by process: PID=$PID command=$NAME\"; echo \"Run: kill $PID\"; exit 1; fi; vite dev --config widget/vite.config.ts",
    "dev:widget-in-host": "bash scripts/dev-widget-in-host.sh",
    "inspect:oauth": "tsx smoke-tests/smoke-oauth-mcp-inspector.ts",
    "trace:oauth": "tsx smoke-tests/auth/capture-browser-trace.ts",
    "start": "bash scripts/start-server.sh",
    "prod:harness": "node scripts/server-harness.js",
    "prod:requests": "node scripts/run-requests.js",
    "prod:diagnostics": "pnpm build && pnpm prod:harness",
    "smoke:dev:stub": "tsx smoke-tests/smoke-dev-stub.ts",
    "smoke:dev:auth": "tsx smoke-tests/smoke-dev-auth.ts",
    "smoke:dev:live": "tsx smoke-tests/smoke-dev-live.ts",
    "smoke:dev:live:auth": "tsx smoke-tests/smoke-dev-live-auth.ts",
    "smoke:oauth-inspector": "tsx smoke-tests/smoke-oauth-mcp-inspector.ts",
    "smoke:oauth-curl": "./smoke-tests/OAUTH-CURL-TESTS.sh",
    "smoke:oauth:spec": "tsx smoke-tests/smoke-oauth-spec.ts",
    "smoke:remote": "tsx smoke-tests/smoke-remote.ts",
    "type-check": "tsc -p tsconfig.lint.json --noEmit && tsc -p widget/tsconfig.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:widget": "vitest run --config vitest.widget.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:ui": "playwright test --grep-invert @a11y",
    "test:a11y": "playwright test --grep @a11y",
    "test:widget:ui": "playwright test --config playwright.widget.config.ts --grep-invert @a11y",
    "test:widget:a11y": "playwright test --config playwright.widget.config.ts --grep @a11y"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.13",
    "@clerk/express": "^2.1.5",
    "@clerk/mcp-tools": "~0.3.1",
    "@elastic/elasticsearch": "^9.3.4",
    "@modelcontextprotocol/ext-apps": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oaknational/build-metadata": "workspace:*",
    "@oaknational/curriculum-sdk": "workspace:*",
    "@oaknational/env": "workspace:*",
    "@oaknational/env-resolution": "workspace:*",
    "@oaknational/logger": "workspace:*",
    "@oaknational/oak-search-sdk": "workspace:*",
    "@oaknational/observability": "workspace:*",
    "@oaknational/result": "workspace:*",
    "@oaknational/sentry-node": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "@sentry/node": "^10.48.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-list-routes": "^1.3.2",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@oaknational/oak-design-tokens": "workspace:*",
    "@oaknational/sdk-codegen": "workspace:*",
    "@playwright/test": "^1.59.1",
    "@sentry/esbuild-plugin": "^5.1.1",
    "@testing-library/react": "^16.3.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-serve-static-core": "^5.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.2",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.4.1",
    "esbuild": "^0.27.7",
    "eslint": "^10.2.0",
    "eslint-plugin-import-x": "^4.16.2",
    "globals": "^17.4.0",
    "happy-dom": "^20",
    "node-mocks-http": "^1.17.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.0",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": "24.x"
  },
  "description": "OAuth-enabled MCP server over HTTP for the Oak National Academy Curriculum API",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git",
    "directory": "apps/oak-curriculum-mcp-streamable-http"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem/tree/main/apps/oak-curriculum-mcp-streamable-http#readme",
  "keywords": [
    "mcp",
    "oauth",
    "http",
    "oak",
    "curriculum",
    "education"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
