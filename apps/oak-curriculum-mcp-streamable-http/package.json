{
  "name": "@oaknational/oak-curriculum-mcp-streamable-http",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "dev": "NODE_ENV=development DEBUG=true LOG_LEVEL=debug REMOTE_MCP_ALLOW_NO_AUTH=true BASE_URL=http://localhost:3333 MCP_CANONICAL_URI=http://localhost:3333/mcp tsx src/dev-server.ts",
    "start": "node dist/index.js",
    "smoke:dev": "tsx scripts/smoke-dev.ts",
    "smoke:dev:live-api": "tsx scripts/smoke-dev.ts --require-live",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint  .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.1",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/mcp-providers-node": "workspace:*",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "jose": "^6.1.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/cors": "^2.8.19",
    "@types/node": "^22",
    "eslint": "^9.35.0",
    "pnpm": "^10.17.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "supertest": "^7.1.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "apps/oak-curriculum-mcp-streamable-http"
  }
}
