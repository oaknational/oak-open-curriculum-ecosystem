{
  "name": "@oaknational/oak-curriculum-mcp-streamable-http",
  "version": "0.0.0-development",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist .turbo",
    "dev": "LOG_LEVEL=debug DANGEROUSLY_DISABLE_AUTH=true ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts",
    "dev:observe": "LOG_LEVEL=debug DANGEROUSLY_DISABLE_AUTH=false ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts 2>&1 | tee .logs/http-dev-$(date +%Y%m%d-%H%M%S).log",
    "dev:observe:noauth": "LOG_LEVEL=debug DANGEROUSLY_DISABLE_AUTH=true ALLOWED_HOSTS=localhost,127.0.0.1,::1 tsx src/index.ts 2>&1 | tee .logs/http-dev-noauth-$(date +%Y%m%d-%H%M%S).log",
    "widget:preview": "tsx scripts/widget-preview-server.ts",
    "start": "node dist/src/index.js",
    "prod:harness": "node scripts/server-harness.js",
    "prod:requests": "node scripts/run-requests.js",
    "prod:diagnostics": "pnpm build && pnpm prod:harness",
    "smoke:dev:stub": "tsx smoke-tests/smoke-dev-stub.ts",
    "smoke:dev:live": "tsx smoke-tests/smoke-dev-live.ts",
    "smoke:dev:live:auth": "tsx smoke-tests/smoke-dev-live-auth.ts",
    "smoke:oauth-inspector": "tsx smoke-tests/smoke-oauth-mcp-inspector.ts",
    "smoke:oauth-curl": "./smoke-tests/OAUTH-CURL-TESTS.sh",
    "smoke:remote": "tsx smoke-tests/smoke-remote.ts",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:e2e:built": "vitest run --config vitest.e2e.built.config.ts",
    "test:ui": "playwright test"
  },
  "dependencies": {
    "@clerk/express": "^1.7.62",
    "@clerk/mcp-tools": "^0.3.1",
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "commander": "^14.0.2",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-list-routes": "^1.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@playwright/test": "^1.57.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24",
    "chokidar": "^5.0.0",
    "eslint": "^9.39.1",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "apps/oak-curriculum-mcp-streamable-http"
  }
}
