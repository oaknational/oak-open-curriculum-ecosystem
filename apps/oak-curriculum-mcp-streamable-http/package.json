{
  "name": "@oaknational/oak-curriculum-mcp-streamable-http",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "dev": "tsx src/dev-server.ts",
    "start": "node dist/index.js",
    "type-check": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^3.23.8",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "@oaknational/mcp-core": "workspace:*",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-providers-node": "workspace:*"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/cors": "^2.8.19",
    "@types/node": "^22",
    "eslint": "^9.35.0",
    "prettier": "^3.6.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "supertest": "^7.1.4"
  }
}
