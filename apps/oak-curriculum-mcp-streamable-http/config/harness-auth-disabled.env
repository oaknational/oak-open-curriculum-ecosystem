# Production Build Harness - Auth Disabled Scenario
#
# This configuration disables authentication entirely for testing.
# Use this to verify server functionality without Clerk dependencies.
#
# Setup:
#   cd apps/oak-curriculum-mcp-streamable-http
#   cp config/harness-auth-disabled.env .env.harness.auth-disabled
#   ENV_FILE=.env.harness.auth-disabled pnpm prod:harness

# Server Configuration
PORT=3001
NODE_ENV=production
LOG_LEVEL=debug

# Auth Configuration - DISABLED
DANGEROUSLY_DISABLE_AUTH=true

# Clerk Authentication - Placeholder keys required by schema (not actually used when auth is disabled)
CLERK_PUBLISHABLE_KEY=pk_test_placeholder_harness_auth_disabled_not_used
CLERK_SECRET_KEY=sk_test_placeholder_harness_auth_disabled_not_used

# Oak API Configuration
OAK_API_KEY=test-key-harness

# Security Settings
ALLOWED_HOSTS=localhost,127.0.0.1,::1
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

