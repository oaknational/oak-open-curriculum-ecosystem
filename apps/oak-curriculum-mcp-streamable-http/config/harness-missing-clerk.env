# Production Build Harness - Missing Clerk Config Scenario
#
# This configuration intentionally OMITS Clerk keys to reproduce potential
# deployment hang or error conditions when auth is enabled but not configured.
# Use this to diagnose authentication initialization failures.
#
# Expected behavior: Should fail fast with clear error or demonstrate hang.
#
# Setup:
#   cd apps/oak-curriculum-mcp-streamable-http
#   cp config/harness-missing-clerk.env .env.harness.missing-clerk
#   ENV_FILE=.env.harness.missing-clerk pnpm prod:harness

# Server Configuration
PORT=3001
NODE_ENV=production
LOG_LEVEL=debug

# Auth Configuration
# DANGEROUSLY_DISABLE_AUTH is NOT set - auth is expected to be enabled
# But Clerk keys are intentionally MISSING to trigger error condition

# Clerk Authentication - INTENTIONALLY INVALID
# Using intentionally invalid placeholder values to trigger validation errors
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Oak API Configuration
OAK_API_KEY=your_oak_api_key_here

# Security Settings (DNS rebinding protection)
ALLOWED_HOSTS=localhost,127.0.0.1,::1

