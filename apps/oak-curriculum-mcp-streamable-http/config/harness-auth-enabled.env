# Production Build Harness - Auth Enabled Scenario
# 
# This configuration enables Clerk OAuth authentication with test keys.
# Use this to verify the full authentication flow works in production build.
#
# Setup:
#   cd apps/oak-curriculum-mcp-streamable-http
#   cp config/harness-auth-enabled.env .env.harness.auth-enabled
#   # Edit .env.harness.auth-enabled with real Clerk test keys
#   ENV_FILE=.env.harness.auth-enabled pnpm prod:harness

# Server Configuration
PORT=3001
NODE_ENV=production
LOG_LEVEL=debug

# Clerk Authentication (Test Keys)
# Replace these with actual Clerk test keys from your Clerk dashboard
# Format: pk_test_* for publishable key, sk_test_* for secret key
CLERK_PUBLISHABLE_KEY=pk_test_example_harness_key_replace_with_real_test_key_from_clerk
CLERK_SECRET_KEY=sk_test_example_harness_key_replace_with_real_test_key_from_clerk

# Oak API Configuration
OAK_API_KEY=test-key-harness

# Security Settings
ALLOWED_HOSTS=localhost,127.0.0.1,::1
ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Auth Configuration
# DANGEROUSLY_DISABLE_AUTH is NOT set - auth is enabled

