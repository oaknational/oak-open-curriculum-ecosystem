{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "include": [
    "operations/**/*.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "build-scripts/**/*.ts",
    "build-scripts/**/*.d.mts",
    "smoke-tests/**/*.ts",
    "tests/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "e2e-tests/**/*.ts",
    "*.config.ts",
    "vitest.e2e.config.ts",
    "bin/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "temp-secrets", "../../.agent/reference/**"]
}
