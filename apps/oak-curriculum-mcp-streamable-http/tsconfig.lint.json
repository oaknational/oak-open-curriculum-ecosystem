{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "incremental": false
  },
  "include": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    "e2e-tests/**/*.ts",
    "tests/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "*.config.ts",
    "vitest.e2e.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "temp-secrets",
    "smoke-tests",
    "../../.agent/reference-docs/**"
  ]
}
