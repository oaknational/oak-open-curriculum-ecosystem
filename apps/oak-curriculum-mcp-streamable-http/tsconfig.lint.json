{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "e2e-tests/**/*.ts",
    "smoke-tests/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "*.config.ts",
    "vitest.e2e.config.ts",
    "bin/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "smoke-tests/auth/**/*", "docs/**/*", "temp-secrets/**/*"]
}
