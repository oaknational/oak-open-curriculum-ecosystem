{
  "name": "@oaknational/oak-curriculum-mcp-stdio",
  "version": "0.0.0-development",
  "private": true,
  "description": "MCP server for the Oak National Academy Curriculum API",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "oak-curriculum-mcp": "./dist/bin/oak-curriculum-mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "24.x"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "deps": "pnpm outdated -r",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "type-check": "tsc -p tsconfig.lint.json --noEmit"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@modelcontextprotocol/ext-apps": "^1.3.2",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@oaknational/curriculum-sdk": "workspace:*",
    "@oaknational/env": "workspace:*",
    "@oaknational/env-resolution": "workspace:*",
    "@oaknational/logger": "workspace:*",
    "@oaknational/oak-search-sdk": "workspace:*",
    "@oaknational/observability": "workspace:*",
    "@oaknational/result": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@oaknational/type-helpers": "workspace:*",
    "@types/node": "^25.5.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git",
    "directory": "apps/oak-curriculum-mcp-stdio"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem/tree/main/apps/oak-curriculum-mcp-stdio#readme",
  "keywords": [
    "mcp",
    "ai",
    "oak",
    "curriculum",
    "education"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
