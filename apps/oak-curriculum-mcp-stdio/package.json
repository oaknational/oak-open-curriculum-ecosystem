{
  "name": "@oaknational/oak-curriculum-mcp-stdio",
  "version": "0.0.0-development",
  "private": true,
  "description": "MCP server for the Oak National Academy Curriculum API",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "oak-curriculum-mcp": "./dist/bin/oak-curriculum-mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "24.x"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "deps": "pnpm outdated -r",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "type-check": "tsc -p tsconfig.lint.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.3",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/curriculum-sdk": "workspace:*",
    "dotenv": "^17.2.3",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^24",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "apps/oak-curriculum-mcp-stdio"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-mcp-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-mcp-ecosystem/tree/main/apps/oak-curriculum-mcp-stdio#readme",
  "keywords": [
    "mcp",
    "ai",
    "oak",
    "curriculum",
    "education"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
