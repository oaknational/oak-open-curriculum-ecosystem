{
  "name": "@oaknational/oak-curriculum-mcp-stdio",
  "version": "0.0.0-development",
  "description": "MCP server for the Oak National Academy Curriculum API",
  "type": "module",
  "main": "dist/src/index.js",
  "bin": {
    "oak-curriculum-mcp": "./dist/bin/oak-curriculum-mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "deps": "pnpm outdated -r",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint --cache .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "type-check": "tsc -p tsconfig.lint.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.2",
    "@oaknational/mcp-core": "workspace:*",
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/mcp-env": "workspace:*",
    "@oaknational/mcp-storage": "workspace:*",
    "@oaknational/mcp-transport": "workspace:*",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "dotenv": "^17.2.1",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.20.5",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "apps/oak-curriculum-mcp-stdio"
  },
  "keywords": [
    "mcp",
    "ai",
    "oak",
    "curriculum",
    "education"
  ],
  "author": "Oak National Academy",
  "license": "MIT"
}
