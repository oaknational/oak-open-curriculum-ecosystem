{
  "name": "@oaknational/mcp-moria",
  "version": "0.0.0-development",
  "description": "Pure abstractions for MCP servers - zero dependencies",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "abstractions",
    "interfaces",
    "pure",
    "zero-dependencies"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-notion-mcp.git",
    "directory": "ecosystem/moria/mcp"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {},
  "devDependencies": {
    "pnpm": "^10.14.0",
    "typescript": "^5.9.2"
  },
  "peerDependencies": {}
}
