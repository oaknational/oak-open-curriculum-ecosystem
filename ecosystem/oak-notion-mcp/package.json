{
  "name": "@oaknational/oak-notion-mcp",
  "version": "0.0.0-development",
  "description": "Notion phenotype - MCP server for Notion integration",
  "keywords": [
    "mcp",
    "notion",
    "ai",
    "llm",
    "claude",
    "phenotype"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "oak-notion-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "@notionhq/client": "^3.0.0",
    "@oaknational/mcp-core": "workspace:^",
    "dotenv": "^16.5.0",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "pnpm": "^10.14.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
