{
  "name": "@oaknational/mcp-histos-storage",
  "version": "0.1.0",
  "description": "Adaptive storage tissue for multi-runtime MCP applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\"",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@oaknational/mcp-moria": "workspace:*"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=22.0.0"
  },
  "author": "Oak National Academy",
  "license": "MIT"
}