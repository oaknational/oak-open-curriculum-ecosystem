#!/usr/bin/env bash
# claude-claude-agent-ops — CLI for monitoring and managing Claude Code background agents
#
# Claude-specific tooling for the Oak MCP Ecosystem. This tool monitors
# background agents spawned by Claude Code's Agent tool, tracks their
# progress via JSONL output files, and helps manage worktree-isolated
# agent changes that need committing.
#
# This is NOT a general-purpose agent framework. It is tightly coupled to
# Claude Code's background agent model (task output files, git worktrees,
# sandbox restrictions). Generalisation is future work.
#
# Usage:
#   claude-claude-agent-ops status          Show status of all Claude background agents
#   claude-claude-agent-ops worktrees       List active agent worktrees with change summary
#   claude-claude-agent-ops log <agent-id>  Show recent activity for a specific agent
#   claude-claude-agent-ops diff [agent-id] Show uncommitted changes (all or specific worktree)
#   claude-claude-agent-ops commit-ready    List agents with uncommitted changes ready to commit
#
# Environment:
#   AGENT_TASKS_DIR   Override Claude tasks output directory (auto-detected)
#   REPO_ROOT         Override repo root (auto-detected)

set -euo pipefail

# --- Configuration -----------------------------------------------------------

REPO_ROOT="${REPO_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || pwd)}"
WORKTREE_DIR="${REPO_ROOT}/.claude/worktrees"

# Auto-detect the tasks output directory from Claude's tmp structure
detect_tasks_dir() {
  local escaped_repo
  escaped_repo=$(echo "${REPO_ROOT}" | sed 's|/|-|g')
  local candidates=(
    "/private/tmp/claude-502/${escaped_repo}/tasks"
    "/private/tmp/claude-501/${escaped_repo}/tasks"
    "/tmp/claude-502/${escaped_repo}/tasks"
    "/tmp/claude-501/${escaped_repo}/tasks"
  )
  for dir in "${candidates[@]}"; do
    if [[ -d "$dir" ]]; then
      echo "$dir"
      return 0
    fi
  done
  # Fallback: find any matching directory
  find /private/tmp /tmp -maxdepth 4 -type d -name "tasks" -path "*/claude-*/${escaped_repo}/*" 2>/dev/null | head -1
}

AGENT_TASKS_DIR="${AGENT_TASKS_DIR:-$(detect_tasks_dir)}"

# --- Helpers ------------------------------------------------------------------

bold()  { printf '\033[1m%s\033[0m' "$1"; }
green() { printf '\033[32m%s\033[0m' "$1"; }
red()   { printf '\033[31m%s\033[0m' "$1"; }
yellow(){ printf '\033[33m%s\033[0m' "$1"; }
dim()   { printf '\033[2m%s\033[0m' "$1"; }

# Extract a metric from an agent's JSONL output file
# Uses jq for reliable JSON parsing
agent_metric() {
  local file="$1" metric="$2"
  case "$metric" in
    turns)
      grep -c '"type":"assistant"' "$file" 2>/dev/null || echo 0
      ;;
    last_tool)
      grep -o '"name":"[^"]*"' "$file" 2>/dev/null | tail -1 | sed 's/"name":"//;s/"//' || echo "—"
      ;;
    last_text)
      grep -o '"text":"[^"]*"' "$file" 2>/dev/null | tail -1 | sed 's/"text":"//;s/"$//' | cut -c1-120 || echo "—"
      ;;
    has_tests)
      grep -cE '"pnpm (test|build|type-check|lint)"' "$file" 2>/dev/null || echo 0
      ;;
    has_commits)
      grep -c '"git commit"' "$file" 2>/dev/null || echo 0
      ;;
    status)
      # Check if the agent's last message was end_turn (completed) or tool_use (still running/stuck)
      local last_stop
      last_stop=$(grep -o '"stop_reason":"[^"]*"' "$file" 2>/dev/null | tail -1 | sed 's/"stop_reason":"//;s/"//')
      if [[ "$last_stop" == "end_turn" ]]; then
        echo "completed"
      elif [[ "$last_stop" == "tool_use" ]]; then
        echo "running"
      else
        echo "unknown"
      fi
      ;;
    description)
      # Extract from the first user message (the agent prompt) - first 80 chars
      grep -o '"prompt":"[^"]*"' "$file" 2>/dev/null | head -1 | sed 's/"prompt":"//;s/"$//' | cut -c1-80 || echo "—"
      ;;
  esac
}

# Get short agent ID (first 8 chars)
short_id() { echo "${1:0:12}"; }

# Check if a worktree exists for an agent ID
worktree_for_agent() {
  local agent_id="$1"
  local short="${agent_id:0:12}"
  local dir="${WORKTREE_DIR}/agent-${short}"
  if [[ -d "$dir" ]]; then
    echo "$dir"
  fi
}

# --- Commands -----------------------------------------------------------------

cmd_status() {
  if [[ -z "$AGENT_TASKS_DIR" || ! -d "$AGENT_TASKS_DIR" ]]; then
    echo "No agent tasks directory found. Are there background agents running?"
    exit 1
  fi

  printf "\n"
  bold "Agent Status Dashboard"
  printf "\n"
  dim "Tasks dir: ${AGENT_TASKS_DIR}"
  printf "\n\n"

  # Header
  printf "%-14s %-10s %6s %12s  %-50s\n" "AGENT ID" "STATUS" "TURNS" "LAST TOOL" "LATEST ACTIVITY"
  printf "%-14s %-10s %6s %12s  %-50s\n" "──────────" "──────" "─────" "─────────" "──────────────────────────────────"

  local count=0
  for output_file in "${AGENT_TASKS_DIR}"/*.output; do
    [[ -f "$output_file" ]] || continue
    local agent_id
    agent_id=$(basename "$output_file" .output)

    # Skip non-agent files (tool results etc.) and short IDs (not agent IDs)
    [[ ${#agent_id} -lt 15 ]] && continue
    local turns
    turns=$(agent_metric "$output_file" turns)
    turns=$(echo "$turns" | tr -d '[:space:]')
    [[ -z "$turns" || "$turns" -lt 2 ]] 2>/dev/null && continue

    local status last_tool last_text
    status=$(agent_metric "$output_file" status)
    last_tool=$(agent_metric "$output_file" last_tool)
    last_text=$(agent_metric "$output_file" last_text)

    # Colorise status
    local status_display
    case "$status" in
      completed) status_display=$(green "done");;
      running)   status_display=$(yellow "running");;
      *)         status_display=$(dim "unknown");;
    esac

    # Check for worktree
    local wt
    wt=$(worktree_for_agent "$agent_id")
    local wt_marker=""
    if [[ -n "$wt" ]]; then
      wt_marker=" [wt]"
    fi

    printf "%-14s %-10s %6s %12s  %.50s%s\n" \
      "$(short_id "$agent_id")" \
      "$status_display" \
      "$turns" \
      "$last_tool" \
      "$last_text" \
      "$wt_marker"
    count=$((count + 1))
  done

  if [[ $count -eq 0 ]]; then
    echo "  No agents found."
  fi

  printf "\n"

  # Worktree summary
  local wt_count
  wt_count=$(find "$WORKTREE_DIR" -maxdepth 1 -type d -name "agent-*" 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$wt_count" -gt 0 ]]; then
    dim "Active worktrees: ${wt_count}"
    printf "\n"
  fi
}

cmd_worktrees() {
  printf "\n"
  bold "Agent Worktrees"
  printf "\n\n"

  if [[ ! -d "$WORKTREE_DIR" ]]; then
    echo "No worktree directory at ${WORKTREE_DIR}"
    exit 0
  fi

  local count=0
  for wt_dir in "${WORKTREE_DIR}"/agent-*; do
    [[ -d "$wt_dir" ]] || continue
    local wt_name branch changes
    wt_name=$(basename "$wt_dir")
    branch=$(git -C "$wt_dir" branch --show-current 2>/dev/null || echo "detached")
    changes=$(git -C "$wt_dir" status --short 2>/dev/null | wc -l | tr -d ' ')

    printf "  %s\n" "$(bold "$wt_name")"
    printf "    Branch:  %s\n" "$branch"
    printf "    Changes: %s files\n" "$changes"

    if [[ "$changes" -gt 0 ]]; then
      git -C "$wt_dir" status --short 2>/dev/null | head -10 | sed 's/^/    /'
    fi
    printf "\n"
    count=$((count + 1))
  done

  if [[ $count -eq 0 ]]; then
    echo "  No active worktrees."
  fi
}

cmd_log() {
  local agent_id="${1:-}"
  if [[ -z "$agent_id" ]]; then
    echo "Usage: claude-agent-ops log <agent-id>"
    echo "  Use 'claude-agent-ops status' to see agent IDs"
    exit 1
  fi

  # Find the output file (support partial ID match)
  local output_file=""
  for f in "${AGENT_TASKS_DIR}"/${agent_id}*.output; do
    if [[ -f "$f" ]]; then
      output_file="$f"
      break
    fi
  done

  if [[ -z "$output_file" || ! -f "$output_file" ]]; then
    echo "No output file found for agent: ${agent_id}"
    exit 1
  fi

  printf "\n"
  bold "Agent Log: $(basename "$output_file" .output)"
  printf "\n\n"

  # Show last 20 assistant text messages
  grep -o '"text":"[^"]*"' "$output_file" 2>/dev/null | tail -20 | while IFS= read -r line; do
    local text
    text=$(echo "$line" | sed 's/"text":"//;s/"$//')
    printf "  %s\n" "$text"
  done

  printf "\n"

  # Show summary stats
  local turns tests commits
  turns=$(agent_metric "$output_file" turns)
  tests=$(agent_metric "$output_file" has_tests)
  commits=$(agent_metric "$output_file" has_commits)

  dim "Turns: ${turns} | Test/build runs: ${tests} | Commit attempts: ${commits}"
  printf "\n"
}

cmd_diff() {
  local agent_id="${1:-}"

  if [[ -n "$agent_id" ]]; then
    # Specific agent worktree
    local wt
    wt=$(worktree_for_agent "$agent_id")
    if [[ -z "$wt" ]]; then
      echo "No worktree found for agent: ${agent_id}"
      exit 1
    fi
    git -C "$wt" diff --stat
    echo
    git -C "$wt" diff
  else
    # Main working tree
    printf "\n"
    bold "Uncommitted changes in main working tree"
    printf "\n\n"
    git diff --stat
    echo
    git diff --name-only -- ':(exclude).claude/worktrees'
  fi
}

cmd_commit_ready() {
  printf "\n"
  bold "Agents with uncommitted changes"
  printf "\n\n"

  # Check main working tree
  local main_changes
  main_changes=$(git status --short -- ':(exclude).claude/worktrees' 2>/dev/null | wc -l | tr -d ' ')
  if [[ "$main_changes" -gt 0 ]]; then
    printf "  %s — %s files changed\n" "$(bold "main working tree")" "$main_changes"
    git status --short -- ':(exclude).claude/worktrees' 2>/dev/null | head -15 | sed 's/^/    /'
    printf "\n"
  fi

  # Check worktrees
  for wt_dir in "${WORKTREE_DIR}"/agent-*; do
    [[ -d "$wt_dir" ]] || continue
    local changes
    changes=$(git -C "$wt_dir" status --short 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$changes" -gt 0 ]]; then
      local wt_name branch
      wt_name=$(basename "$wt_dir")
      branch=$(git -C "$wt_dir" branch --show-current 2>/dev/null || echo "?")
      printf "  %s (%s) — %s files changed\n" "$(bold "$wt_name")" "$branch" "$changes"
      git -C "$wt_dir" status --short 2>/dev/null | head -10 | sed 's/^/    /'
      printf "\n"
    fi
  done
}

cmd_help() {
  cat <<'HELP'
claude-agent-ops — CLI for monitoring and managing Claude background agents

Commands:
  status          Show status dashboard for all background agents
  worktrees       List active agent worktrees with change summary
  log <id>        Show recent activity log for a specific agent (supports partial ID)
  diff [id]       Show uncommitted changes (main tree if no ID, or specific worktree)
  commit-ready    List all locations with uncommitted agent changes
  help            Show this help message

Examples:
  claude-agent-ops status                    # Dashboard of all agents
  claude-agent-ops log ae5ee7b               # Last 20 messages from agent ae5ee7b...
  claude-agent-ops worktrees                 # See which worktrees have changes
  claude-agent-ops commit-ready              # Find what needs committing

Environment Variables:
  AGENT_TASKS_DIR   Override auto-detected tasks output directory
  REPO_ROOT         Override auto-detected repository root
HELP
}

# --- Main ---------------------------------------------------------------------

main() {
  local cmd="${1:-status}"
  shift || true

  case "$cmd" in
    status)       cmd_status "$@";;
    worktrees)    cmd_worktrees "$@";;
    log)          cmd_log "$@";;
    diff)         cmd_diff "$@";;
    commit-ready) cmd_commit_ready "$@";;
    help|--help|-h) cmd_help;;
    *)
      echo "Unknown command: $cmd"
      echo "Run 'claude-agent-ops help' for usage."
      exit 1
      ;;
  esac
}

main "$@"
