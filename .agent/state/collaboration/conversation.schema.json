{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "conversation.schema.json",
  "title": "Agent Collaboration Decision Thread",
  "description": "Lightweight async decision-thread file for structured overlap discussion, concrete decision requests, decisions, resolutions, and evidence. Decision threads are operational state under .agent/state/collaboration/conversations/ and are distinct from shared log narrative, active claims, napkin learning, and durable thread records.",
  "$comment_compatibility": "Additive-only schema evolution within a major version. v1.x agents reading v1.y files (y > x) preserve unrecognised fields on write-back; major-version mismatch causes the agent to bail out with an error pointing at the protocol upgrade. additionalProperties is false for authored v1.0.0 files: new fields require a coordinated schema_version bump. This v1.0.0 contract intentionally excludes sidebar, timeout, and escalation fields.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "conversation_id",
    "thread",
    "status",
    "title",
    "participants",
    "opened_at",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0.0"],
      "description": "Semantic version of this decision-thread schema."
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9-]*$",
      "description": "Stable slug-like identifier unique within .agent/state/collaboration/conversations/."
    },
    "thread": {
      "type": "string",
      "minLength": 1,
      "description": "Slug of the work thread this decision thread belongs to."
    },
    "status": {
      "type": "string",
      "enum": ["open", "closed"],
      "description": "Whether the decision thread is still accepting entries."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable topic for this decision thread."
    },
    "participants": {
      "type": "array",
      "minItems": 1,
      "description": "Agents or humans who have participated or are expected to respond.",
      "items": {
        "$ref": "active-claims.schema.json#/$defs/agent_id"
      }
    },
    "opened_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this decision thread opened."
    },
    "closed_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this decision thread closed."
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "description": "Ordered decision-thread entries.",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "closed"
          }
        },
        "required": ["status"]
      },
      "then": {
        "required": ["closed_at"]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "open"
          }
        },
        "required": ["status"]
      },
      "then": {
        "not": {
          "required": ["closed_at"]
        }
      }
    }
  ],
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entry_id", "kind", "created_at"],
      "properties": {
        "entry_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9][a-z0-9-]*$",
          "description": "Stable identifier unique within this decision thread."
        },
        "kind": {
          "type": "string",
          "enum": [
            "message",
            "claim_update",
            "decision_request",
            "decision",
            "resolution",
            "evidence"
          ],
          "description": "Narrow decision-thread entry kind."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when this entry was authored."
        },
        "author": {
          "$ref": "active-claims.schema.json#/$defs/agent_id",
          "description": "Optional author identity for the entry."
        },
        "body": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable content for message, claim update, decision request, decision, or resolution entries."
        },
        "claim_id": {
          "type": "string",
          "format": "uuid",
          "description": "Claim identifier referenced by a claim_update entry."
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "description": "Structured evidence references compatible with active-claims evidence refs.",
          "items": {
            "$ref": "active-claims.schema.json#/$defs/evidence_ref"
          }
        },
        "outcome": {
          "type": "string",
          "enum": ["resolved", "deferred", "superseded", "no_action_needed"],
          "description": "Resolution outcome for a resolution entry."
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "message"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["body"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "claim_update"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["claim_id", "body"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "decision_request"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["body"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "decision"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["body"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "resolution"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["outcome", "body"]
          }
        },
        {
          "if": {
            "properties": {
              "kind": {
                "const": "evidence"
              }
            },
            "required": ["kind"]
          },
          "then": {
            "required": ["evidence"]
          }
        }
      ]
    }
  }
}
