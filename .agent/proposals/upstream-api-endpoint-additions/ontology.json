  "glossary": {
    "tier": {
      "definition": "Difficulty level for GCSE courses, determining paper content and grade boundaries",
      "values": ["foundation", "higher"],
      "context": "KS4 maths and science only",
      "appliesTo": ["maths", "science"]
    },
    "examBoard": {
      "definition": "Official awarding body that sets and grades GCSE qualifications",
      "values": ["aqa", "ocr", "edexcel", "eduqas", "edexcelb"],
      "context": "KS4 subjects with multiple exam board options"
    },
    "thread": {
      "definition": "Conceptual strand that links related units across year groups, showing how knowledge builds progressively",
      "context": "Used for vertical curriculum navigation"
    },
    "sequence": {
      "definition": "API internal structure for organising curriculum data; one sequence can generate multiple programme views",
      "context": "API/technical concept, not user-facing"
    },
    "programme": {
      "definition": "User-facing curriculum pathway combining subject, key stage, tier, and exam board",
      "context": "What teachers navigate on Oak Web Application"
    },
    "unitOptions": {
      "definition": "Alternative content choices within a unit position, allowing teacher personalisation",
      "context": "KS4 subjects like English (set texts), History (periods), Geography (topics)"
    },
    "ks4Options": {
      "definition": "Alternative sequence variants at KS4, exposed via ks4Options field on sequences",
      "context": "Citizenship, Computing, PE have 'core' vs 'gcse' options. Not a separate 'pathway' concept."
    },
    "priorKnowledge": {
      "definition": "Prerequisite understanding required before teaching a unit",
      "context": "Listed at unit level to support sequencing decisions"
    },
    "category": {
      "definition": "Subject-specific grouping of units by content area",
      "context": "Only English, Science, and Religious Education have categories"
    }
  },

