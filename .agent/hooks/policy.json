      "description": "Remind the agent to ground itself at session start."
    },
    "preCommit": {
      "quality_gate_reminder": "Run the required quality gates; `pnpm check` is the canonical aggregate gate.",
      "description": "Remind the agent to run quality gates before committing."
    }
