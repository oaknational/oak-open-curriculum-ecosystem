{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "castr-ir.schema.json",
  "title": "Castr IR Contract",
  "description": "Machine-readable contract for the normalised intermediate representation produced by @engraph/castr.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "source", "policy", "schemas", "endpoints"],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "enum": ["castr-ir/1"],
      "description": "IR contract version."
    },
    "source": {
      "$ref": "#/$defs/source"
    },
    "policy": {
      "$ref": "#/$defs/policy"
    },
    "schemas": {
      "type": "array",
      "description": "Normalised schema registry entries, ordered deterministically.",
      "items": {
        "$ref": "#/$defs/schemaRegistryEntry"
      }
    },
    "endpoints": {
      "type": "array",
      "description": "Normalised endpoint entries, ordered deterministically.",
      "items": {
        "$ref": "#/$defs/endpointEntry"
      }
    },
    "diagnostics": {
      "type": "array",
      "description": "Optional diagnostics emitted during parsing or normalisation.",
      "items": {
        "$ref": "#/$defs/diagnosticEntry"
      }
    },
    "meta": {
      "type": "object",
      "description": "Optional metadata about the generator or inputs.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strictObjects", "failFast", "losslessOpenApi"],
      "properties": {
        "strictObjects": {
          "const": true,
          "description": "When true, object schemas must reject unknown keys."
        },
        "failFast": {
          "const": true,
          "description": "When true, validation must fail fast with explicit errors."
        },
        "losslessOpenApi": {
          "const": true,
          "description": "When true, OpenAPI output must preserve all input data."
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["openapi", "json-schema", "zod"],
          "description": "Input format for the IR."
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Human readable identifier for the input source."
        },
        "hash": {
          "type": "string",
          "description": "Optional content hash, e.g. sha256:..."
        },
        "version": {
          "type": "string",
          "description": "Optional version string provided by the input source."
        }
      }
    },
    "schemaRegistryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "jsonSchema"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical schema name used as a stable reference."
        },
        "source": {
          "type": "string",
          "enum": ["component", "inline", "derived"],
          "description": "Origin of the schema within the source document."
        },
        "jsonSchema": {
          "type": ["object", "boolean"],
          "description": "Normalised JSON Schema (2020-12 compatible)."
        },
        "zodExportName": {
          "type": "string",
          "description": "Optional Zod v4 export identifier for this schema."
        },
        "tsTypeName": {
          "type": "string",
          "description": "Optional TypeScript type name emitted for this schema."
        },
        "description": {
          "type": "string",
          "description": "Optional schema description." 
        }
      }
    },
    "endpointEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path", "colonPath", "operationId", "responses"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["get", "post", "put", "patch", "delete", "head", "options", "trace"],
          "description": "HTTP method in lower case."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "OpenAPI path template (e.g. /lessons/{lesson})."
        },
        "colonPath": {
          "type": "string",
          "minLength": 1,
          "description": "Colon path variant (e.g. /lessons/:lesson)."
        },
        "operationId": {
          "type": "string",
          "minLength": 1,
          "description": "OpenAPI operationId."
        },
        "summary": {
          "type": "string",
          "description": "Optional short summary."
        },
        "description": {
          "type": "string",
          "description": "Optional longer description."
        },
        "tags": {
          "type": "array",
          "description": "Optional tags from the OpenAPI operation.",
          "items": {
            "type": "string"
          }
        },
        "parameters": {
          "type": "array",
          "description": "Optional parameters for the operation.",
          "items": {
            "$ref": "#/$defs/parameterEntry"
          }
        },
        "requestBody": {
          "$ref": "#/$defs/requestBodyEntry"
        },
        "responses": {
          "type": "array",
          "description": "Response descriptors for this operation.",
          "items": {
            "$ref": "#/$defs/responseEntry"
          }
        }
      }
    },
    "parameterEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "in"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Parameter name."
        },
        "in": {
          "type": "string",
          "enum": ["path", "query", "header", "cookie"],
          "description": "Parameter location."
        },
        "required": {
          "type": "boolean",
          "description": "Whether the parameter is required."
        },
        "schemaRef": {
          "type": "string",
          "description": "Reference to a schema registry entry by name."
        },
        "jsonSchema": {
          "type": ["object", "boolean"],
          "description": "Inline JSON Schema for the parameter when no schemaRef is provided."
        }
      }
    },
    "requestBodyEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": {
        "required": {
          "type": "boolean",
          "description": "Whether the request body is required."
        },
        "content": {
          "type": "array",
          "minItems": 1,
          "description": "Content entries for the request body.",
          "items": {
            "$ref": "#/$defs/contentEntry"
          }
        }
      }
    },
    "contentEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mediaType"],
      "properties": {
        "mediaType": {
          "type": "string",
          "minLength": 1,
          "description": "Media type (e.g. application/json)."
        },
        "schemaRef": {
          "type": "string",
          "description": "Reference to a schema registry entry by name."
        },
        "jsonSchema": {
          "type": ["object", "boolean"],
          "description": "Inline JSON Schema for the content when no schemaRef is provided."
        }
      }
    },
    "responseEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "source"],
      "properties": {
        "status": {
          "description": "HTTP status code or default response.",
          "oneOf": [
            {
              "type": "string",
              "pattern": "^(default|[1-5][0-9][0-9])$"
            },
            {
              "type": "integer",
              "minimum": 100,
              "maximum": 599
            }
          ]
        },
        "description": {
          "type": "string",
          "description": "Optional response description."
        },
        "mediaType": {
          "type": "string",
          "description": "Optional media type."
        },
        "schemaRef": {
          "type": "string",
          "description": "Reference to a schema registry entry by name."
        },
        "jsonSchema": {
          "type": ["object", "boolean"],
          "description": "Inline JSON Schema for the response when no schemaRef is provided."
        },
        "source": {
          "type": "string",
          "enum": ["component", "inline", "void"],
          "description": "Origin of the response schema."
        }
      }
    },
    "diagnosticEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "code", "message"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["info", "warning", "error"]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "pointer": {
          "type": "string",
          "description": "Optional pointer to the source location that triggered the diagnostic."
        }
      }
    }
  }
}
