# Oak Curriculum API Configuration
OAK_API_URL=https://open-api.thenational.academy/api/v0
OAK_API_KEY=your_oak_api_key_here

# Clerk Authentication (for MCP streamable HTTP server)
# Get these from: https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=pk_test_public123abc
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Optional security overrides (defaults cover localhost or Vercel URL automatically)
# ALLOWED_HOSTS=localhost,127.0.0.1,::1
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3333

# The base url for the `pnpm smoke:remote` tests
SMOKE_REMOTE_BASE_URL=https://example.com/mcp

# Notion API Configuration (optional - for Notion MCP server)
NOTION_API_KEY=your_notion_api_key_here

# Optional: Testing only, does not affect production at all.
OAK_MCP_URL=http://localhost:3333

# Optional: Logging
LOG_LEVEL=info
# MCP_STREAMABLE_HTTP_LOG_FILE=apps/oak-curriculum-mcp-streamable-http/.logs/dev-server.log
