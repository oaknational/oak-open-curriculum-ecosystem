# Oak MCP Ecosystem - Environment Variables
#
# CONTRIBUTION LEVELS:
# - Level 1 (Unit tests, type-check): No variables required
# - Level 2 (Local dev servers): OAK_API_KEY required
# - Level 3 (Full E2E testing): All variables below
#
# See docs/development/environment-variables.md for complete reference

# Oak Curriculum API Configuration
OAK_API_URL=https://open-api.thenational.academy/api/v0
OAK_API_KEY=your_oak_api_key_here

# Clerk Authentication (for MCP streamable HTTP server)
# Get these from: https://dashboard.clerk.com/
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
CLERK_SECRET_KEY=your_clerk_secret_key_here

# Optional: Auto-includes localhost addresses (+ Vercel URL if deployed)
# ALLOWED_HOSTS=localhost,127.0.0.1,::1

# CORS Configuration
# CORS_MODE controls how origin access is handled (default: automatic)
#   - 'allow_all': Permits all origins (useful for development/testing)
#   - 'explicit': Only allows origins from ALLOWED_ORIGINS (strict)
#   - 'automatic': Smart default (all in local dev, self-only in Vercel)
# CORS_MODE=automatic

# Optional: Comma-separated list of allowed origins for CORS
# Only used in 'explicit' and 'automatic' modes
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3333

# The base url for the `pnpm smoke:remote` tests
SMOKE_REMOTE_BASE_URL=https://example.com/mcp

# CRITICAL: Completely disables auth requirements
# DANGEROUSLY_DISABLE_AUTH=true

# Elasticsearch (optional — enables semantic search tools in MCP servers)
# Same credentials used by apps/oak-search-cli
# See: docs/ES_SERVERLESS_SETUP.md
# ELASTICSEARCH_URL=https://your-elasticsearch-url-here
# ELASTICSEARCH_API_KEY=your_elasticsearch_api_key_here

# Optional: Logging
LOG_LEVEL=info
