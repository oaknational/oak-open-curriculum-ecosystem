{
  "name": "@oaknational/mcp-ecosystem",
  "version": "0.5.0",
  "private": true,
  "description": "MCP ecosystem - A collection of MCP servers and supporting frameworks and libraries",
  "type": "module",
  "scripts": {
    "type-gen": "turbo run --continue type-gen",
    "doc-gen": "turbo run --continue doc-gen",
    "build": "turbo run --continue build",
    "clean": "turbo run --continue clean",
    "dev": "turbo run --continue dev",
    "format": "prettier --write --cache .",
    "format:check": "prettier --check --cache .",
    "markdownlint": "markdownlint --fix .",
    "lint": "turbo run --continue lint",
    "test": "turbo run --continue test",
    "test:e2e": "E2E_REAL_API=true turbo run --continue test:e2e",
    "type-check": "turbo run --continue type-check",
    "qg": "pnpm i && pnpm type-gen --only && pnpm build --only && pnpm type-check --only && pnpm lint --only -- --fix && pnpm doc-gen && pnpm format && pnpm markdownlint && pnpm test && pnpm test:e2e",
    "identity-check": "node scripts/identity-check.mjs --mode=enforce",
    "identity-report": "node scripts/identity-check.mjs --mode=report",
    "fix": "pnpm format && pnpm markdownlint --fix && pnpm lint -- --fix",
    "prepare": "husky",
    "publish:dry": "pnpm -r publish --dry-run",
    "publish:packages": "pnpm -r publish",
    "analyze": "pnpm run analyze:deps && pnpm run analyze:modules",
    "analyze:deps": "madge ecosystem/ --circular --image .agent/generalisation-opportunities-analysis/dependency-graph.svg",
    "analyze:circular": "madge ecosystem/ --circular",
    "analyze:modules": "tsx scripts/analyze-modules.ts",
    "analyze:outdated": "pnpm outdated -r"
  },
  "keywords": [
    "mcp",
    "notion",
    "ai",
    "llm",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.16.0+sha512.8066e7b034217b700a9a4dbb3a005061d641ba130a89915213a10b3ca4919c19c037bec8066afdc559b89635fdb806b16ea673f2468fbb28aabfa13c53e3f769",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.32.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^24.2.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cloc": "2.6.0-cloc",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.45.0",
    "pnpm": "^10.16.0",
    "prettier": "^3.6.2",
    "semantic-release": "^24.2.7",
    "supertest": "^7.1.4",
    "ts-morph": "^27.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "turbo": "^2.5.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.0",
    "vitest": "^3.2.4"
  }
}
