{
  "name": "@oaknational/open-curriculum-ecosystem",
  "version": "1.1.1",
  "private": true,
  "description": "Oak National Academy MCP ecosystem - A collection of MCP servers, frameworks, libraries, and supporting services",
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "type": "module",
  "scripts": {
    "sdk-codegen": "turbo run --continue sdk-codegen",
    "vocab-gen": "pnpm --filter @oaknational/sdk-codegen vocab-gen",
    "doc-gen": "turbo run --continue doc-gen",
    "build": "turbo run --continue build",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run --continue dev",
    "lint": "turbo run --continue lint",
    "lint:fix": "turbo run --continue lint:fix",
    "lint:clean": "rm -rf **/.eslintcache",
    "test": "turbo run --continue test",
    "test:root-scripts": "vitest run --config vitest.config.ts",
    "test:field-integrity": "node scripts/run-field-integrity-tests.mjs",
    "mutate": "turbo run --continue mutate",
    "test:e2e": "turbo run --continue test:e2e",
    "test:ui": "turbo run --continue test:ui",
    "smoke:dev:stub": "LOG_LEVEL=debug turbo run smoke:dev:stub",
    "smoke:dev:live": "LOG_LEVEL=debug turbo run smoke:dev:live",
    "smoke:dev:live:auth": "LOG_LEVEL=debug turbo run smoke:dev:live:auth",
    "test:all": "pnpm test && pnpm test:e2e && pnpm test:ui && pnpm smoke:dev:stub",
    "smoke:remote": "LOG_LEVEL=debug turbo run smoke:remote",
    "agent-tools:build": "pnpm --filter @oaknational/agent-tools build",
    "agent-tools:lint": "pnpm --filter @oaknational/agent-tools lint",
    "agent-tools:test": "pnpm --filter @oaknational/agent-tools test",
    "agent-tools:claude-agent-ops": "pnpm --filter @oaknational/agent-tools claude-agent-ops",
    "agent-tools:cursor-session-from-claude-session": "pnpm --filter @oaknational/agent-tools cursor-session-from-claude-session",
    "type-check": "turbo run --continue type-check",
    "format:root": "prettier --write --cache .",
    "format-check:root": "prettier --check .",
    "markdownlint:root": "markdownlint --fix .",
    "markdownlint-check:root": "markdownlint .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "depcruise": "depcruise apps packages agent-tools",
    "depcruise:report": "depcruise apps packages agent-tools --output-type dot > dependency-graph.dot",
    "shellcheck": "shellcheck scripts/*.sh apps/*/scripts/*.sh apps/*/smoke-tests/*.sh",
    "subagents:check": "node scripts/validate-subagents.mjs",
    "portability:check": "node scripts/validate-portability.mjs",
    "practice:fitness": "node scripts/validate-practice-fitness.mjs",
    "practice:fitness:informational": "node scripts/validate-practice-fitness.mjs --informational",
    "qa:oauth": "cd apps/oak-curriculum-mcp-streamable-http && LOG_LEVEL=debug node dist/index.js",
    "make": "pnpm i && turbo run build type-check doc-gen lint:fix && pnpm subagents:check && pnpm portability:check && pnpm practice:fitness:informational && pnpm markdownlint:root && pnpm format:root",
    "qg": "pnpm format-check:root && pnpm markdownlint-check:root && pnpm subagents:check && pnpm portability:check && pnpm test:root-scripts && turbo run type-check lint test test:ui test:e2e smoke:dev:stub",
    "re-build": "pnpm clean && pnpm install && pnpm sdk-codegen && pnpm build",
    "fix": "pnpm format:root && pnpm markdownlint:root && pnpm lint:fix",
    "check": "pnpm secrets:scan:all && pnpm clean && pnpm test:root-scripts && turbo run sdk-codegen build type-check doc-gen lint:fix test test:e2e test:ui smoke:dev:stub && pnpm subagents:check && pnpm portability:check && pnpm markdownlint:root && pnpm format:root",
    "app:search": "pnpm run dev --filter=@oaknational/search-cli",
    "app:mcp": "pnpm run dev --filter=@oaknational/oak-curriculum-mcp-streamable-http",
    "prepare": "husky",
    "publish:dry": "pnpm -r publish --dry-run",
    "publish:packages": "pnpm -r publish",
    "outdated": "pnpm outdated -r",
    "update:playwright": "pnpm install --save-dev -w @playwright/test@latest && pnpm exec playwright install --with-deps",
    "secrets:scan": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--branches --tags\"",
    "secrets:scan:all": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--branches --tags --full-history\"",
    "secrets:scan:all-refs": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--all --full-history\""
  },
  "keywords": [
    "mcp",
    "curriculum",
    "oak",
    "sdk",
    "education",
    "ai",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem#readme",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "license": "MIT",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint-plugin-import>eslint": "10",
        "eslint-plugin-import-x>eslint": "10",
        "eslint-plugin-react>eslint": "10",
        "eslint-plugin-react-hooks>eslint": "10"
      }
    },
    "overrides": {
      "axios": ">=1.13.5",
      "brace-expansion": ">=5.0.5",
      "csstype": ">=3.2.3",
      "file-type": ">=21.3.2",
      "hono": ">=4.12.4",
      "@hono/node-server": ">=1.19.10",
      "js-yaml": ">=4.1.1",
      "picomatch": ">=4.0.4",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "sucrase": ">=3.35.1"
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "core-js",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@stryker-mutator/vitest-runner": "^9.6.0",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.2",
    "cloc": "2.6.0-cloc",
    "dependency-cruiser": "^17.3.9",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "knip": "^6.0.6",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "shellcheck": "^4.1.0",
    "supertest": "^7.2.2",
    "ts-morph": "^27.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typescript": "^5",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
