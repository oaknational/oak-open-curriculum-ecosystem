{
  "name": "@oaknational/mcp-ecosystem",
  "version": "0.5.0",
  "private": true,
  "description": "Oak National Academy MCP ecosystem - A collection of MCP servers, frameworks, libraries, and supporting services",
  "type": "module",
  "scripts": {
    "type-gen": "turbo run --continue type-gen",
    "vocab-gen": "pnpm --filter @oaknational/oak-curriculum-sdk vocab-gen",
    "doc-gen": "turbo run --continue doc-gen",
    "build": "turbo run --continue build",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run --continue dev",
    "lint": "turbo run --continue lint",
    "lint:fix": "turbo run --continue lint:fix",
    "lint:clean": "rm -rf **/.eslintcache",
    "test": "turbo run --continue test",
    "mutate": "turbo run --continue mutate",
    "test:e2e": "turbo run --continue test:e2e",
    "test:ui": "turbo run --continue test:ui",
    "smoke:dev:stub": "LOG_LEVEL=debug turbo run smoke:dev:stub",
    "smoke:dev:live": "LOG_LEVEL=debug turbo run smoke:dev:live",
    "smoke:dev:live:auth": "LOG_LEVEL=debug turbo run smoke:dev:live:auth",
    "test:all": "pnpm test && pnpm test:e2e && pnpm test:ui && pnpm smoke:dev:stub",
    "smoke:remote": "LOG_LEVEL=debug turbo run smoke:remote",
    "type-check": "turbo run --continue type-check",
    "format:root": "prettier --write --cache .",
    "format-check:root": "prettier --check .",
    "markdownlint:root": "markdownlint --fix .",
    "markdownlint-check:root": "markdownlint .",
    "qa:oauth": "cd apps/oak-curriculum-mcp-streamable-http && LOG_LEVEL=debug node dist/index.js",
    "make": "pnpm i && turbo run build type-check doc-gen lint:fix && pnpm markdownlint:root && pnpm format:root",
    "qg": "pnpm format-check:root && pnpm markdownlint-check:root && turbo run type-check lint test test:ui test:e2e smoke:dev:stub",
    "re-build": "pnpm clean && pnpm install && pnpm type-gen && pnpm build",
    "fix": "pnpm format:root && pnpm markdownlint:root && pnpm lint:fix",
    "check": "pnpm clean && turbo run type-gen build type-check doc-gen lint:fix test test:e2e test:ui smoke:dev:stub --concurrency=2 && pnpm markdownlint:root && pnpm format:root",
    "app:search": "pnpm run dev --filter=@oaknational/search-cli",
    "app:mcp": "pnpm run dev --filter=@oaknational/oak-curriculum-mcp-streamable-http",
    "prepare": "husky",
    "publish:dry": "pnpm -r publish --dry-run",
    "publish:packages": "pnpm -r publish",
    "outdated": "pnpm outdated -r",
    "update:playwright": "pnpm install --save-dev -w @playwright/test@latest && pnpm exec playwright install --with-deps"
  },
  "keywords": [
    "mcp",
    "notion",
    "ai",
    "llm",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.29.2+sha512.bef43fa759d91fd2da4b319a5a0d13ef7a45bb985a3d7342058470f9d2051a3ba8674e629672654686ef9443ad13a82da2beb9eeb3e0221c87b8154fff9d74b8",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "axios": "^1.12.2",
      "sucrase": ">=3.35.1",
      "js-yaml": ">=4.1.1",
      "csstype": "^3.2.3"
    },
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "core-js",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^9.39.1",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stryker-mutator/core": "^9.4.0",
    "@stryker-mutator/typescript-checker": "^9.4.0",
    "@stryker-mutator/vitest-runner": "^9.4.0",
    "@types/node": "^24",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.49.0",
    "@typescript-eslint/parser": "^8.49.0",
    "@vitest/coverage-v8": "^4.0.15",
    "cloc": "2.6.0-cloc",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.47.0",
    "prettier": "^3.7.4",
    "semantic-release": "^25.0.2",
    "supertest": "^7.1.4",
    "ts-morph": "^27.0.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^4.0.15"
  }
}
