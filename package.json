{
  "name": "@oaknational/open-curriculum-ecosystem",
  "version": "1.15.0",
  "private": true,
  "description": "Oak National Academy open curriculum data ecosystem - tools and services for working with the Oak Open Curriculum data",
  "author": "https://github.com/jimCresswell",
  "contributors": [
    {
      "name": "Jim Cresswell",
      "email": "contact@jimcresswell.net",
      "url": "https://jimcresswell.net"
    },
    {
      "name": "Mark Hodierne",
      "email": "mark@markhodierne.com"
    },
    {
      "name": "John Roberts",
      "email": "john.roberts@thenational.academy"
    },
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "type": "module",
  "scripts": {
    "sdk-codegen": "turbo run --continue sdk-codegen",
    "vocab-gen": "pnpm --filter @oaknational/sdk-codegen vocab-gen",
    "doc-gen": "turbo run --continue doc-gen",
    "build": "turbo run --continue build",
    "clean": "turbo run clean && rm -rf .turbo",
    "dev": "turbo run --continue dev",
    "test": "turbo run --continue test",
    "test:widget": "turbo run --continue test:widget",
    "repo-validators:check": "pnpm --filter @oaknational/eslint-plugin-standards validate-boundaries && pnpm --filter @oaknational/agent-tools validate-no-stale-script-invocations && pnpm --filter @oaknational/agent-tools validate-external-data-files",
    "test:field-integrity": "vitest run --config vitest.field-integrity.config.ts",
    "mutate": "turbo run --continue mutate",
    "test:e2e": "turbo run --continue test:e2e",
    "test:ui": "turbo run --continue test:ui",
    "test:a11y": "turbo run --continue test:a11y",
    "test:widget:ui": "turbo run --continue test:widget:ui",
    "test:widget:a11y": "turbo run --continue test:widget:a11y",
    "test:all": "turbo run --continue test test:widget test:e2e test:ui test:a11y test:widget:ui test:widget:a11y",
    "agent-tools:build": "pnpm --filter @oaknational/agent-tools build",
    "agent-tools:lint": "pnpm --filter @oaknational/agent-tools lint",
    "agent-tools:test": "pnpm --filter @oaknational/agent-tools test",
    "agent-tools:test:e2e": "pnpm --filter @oaknational/agent-tools test:e2e",
    "agent-tools:smoke:collaboration-tui": "pnpm --filter @oaknational/agent-tools smoke:collaboration-tui",
    "agent-tools": "pnpm --filter @oaknational/agent-tools agent-tools",
    "agent-tools:agent-identity": "pnpm --filter @oaknational/agent-tools agent-identity",
    "agent-tools:collaboration-state": "pnpm --filter @oaknational/agent-tools collaboration-state",
    "agent-tools:claude-agent-ops": "pnpm --filter @oaknational/agent-tools claude-agent-ops",
    "agent-tools:commit-queue": "pnpm --filter @oaknational/agent-tools commit-queue",
    "agent-tools:cursor-session-from-claude-session": "pnpm --filter @oaknational/agent-tools cursor-session-from-claude-session",
    "agent-tools:install-cursor-statusline": "node .cursor/scripts/install-statusline-cli-config.mjs",
    "agent-tools:codex-reviewer-resolve": "pnpm --filter @oaknational/agent-tools codex-reviewer-resolve",
    "agent-tools:branch-touched-files": "pnpm --filter @oaknational/agent-tools branch-touched-files",
    "agent-tools:codex-exec": "pnpm --filter @oaknational/agent-tools codex-exec",
    "agent-tools:repo-check": "pnpm --filter @oaknational/agent-tools repo-check",
    "agent-tools:check-blocked-patterns": "pnpm --filter @oaknational/agent-tools check-blocked-patterns",
    "agent-tools:check-blocked-content": "pnpm --filter @oaknational/agent-tools check-blocked-content",
    "agent-tools:check-commit-message": "pnpm --filter @oaknational/agent-tools check-commit-message",
    "agent-tools:check-commit-skill-advisories": "pnpm --filter @oaknational/agent-tools check-commit-skill-advisories",
    "agent-tools:prevent-accidental-major-version": "pnpm --filter @oaknational/agent-tools prevent-accidental-major-version",
    "practice:substrate:check": "pnpm --filter @oaknational/agent-tools practice-substrate -- check",
    "type-check": "turbo run --continue type-check",
    "format:root": "prettier --write --cache .",
    "format-check:root": "prettier --check .",
    "markdownlint:root": "markdownlint --dot --fix .",
    "markdownlint-check:root": "markdownlint --dot .",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "depcruise": "depcruise apps packages agent-tools",
    "depcruise:report": "depcruise apps packages agent-tools --output-type dot > dependency-graph.dot",
    "lint": "turbo run --continue lint && pnpm lint:shell",
    "lint:fix": "turbo run --continue lint:fix --only && pnpm lint:shell:syntax",
    "lint:clean": "rm -rf **/.eslintcache",
    "lint:shell": "pnpm lint:shell:syntax",
    "lint:shell:syntax": "bash -n apps/oak-curriculum-mcp-streamable-http/scripts/*.sh",
    "subagents:check": "pnpm --filter @oaknational/agent-tools validate-subagents",
    "portability:check": "pnpm --filter @oaknational/agent-tools validate-portability",
    "portability:fix": "pnpm --filter @oaknational/agent-tools validate-portability:fix",
    "skills:check": "pnpm --filter @oaknational/agent-tools -s build && node agent-tools/dist/src/bin/skills-adapter-generate.js --check --prefix=oak-",
    "practice:fitness": "pnpm --filter @oaknational/agent-tools validate-practice-fitness",
    "practice:fitness:informational": "pnpm --filter @oaknational/agent-tools validate-practice-fitness -- --informational",
    "practice:fitness:strict-hard": "pnpm --filter @oaknational/agent-tools validate-practice-fitness -- --strict-hard",
    "practice:vocabulary": "pnpm --filter @oaknational/agent-tools validate-fitness-vocabulary",
    "qa:oauth": "cd apps/oak-curriculum-mcp-streamable-http && LOG_LEVEL=debug node dist/index.js",
    "make": "pnpm i && turbo run build type-check doc-gen lint:fix && pnpm subagents:check && pnpm portability:check && pnpm practice:fitness:informational && pnpm markdownlint:root && pnpm format:root",
    "re-build": "pnpm clean && pnpm install && turbo run build",
    "fix": "pnpm format:root && pnpm markdownlint:root && pnpm lint:fix",
    "check": "pnpm secrets:scan && pnpm clean && pnpm repo-validators:check && turbo run --continue sdk-codegen build type-check doc-gen lint test test:widget test:e2e test:ui test:a11y test:widget:ui test:widget:a11y && pnpm lint:shell && pnpm subagents:check && pnpm portability:check && pnpm skills:check && pnpm knip && pnpm depcruise && pnpm markdownlint-check:root && pnpm format-check:root",
    "check:profile": "pnpm agent-tools:repo-check profile",
    "app:search": "pnpm run dev --filter=@oaknational/search-cli",
    "app:mcp": "pnpm run dev --filter=@oaknational/oak-curriculum-mcp-streamable-http",
    "prepare": "husky",
    "publish:dry": "pnpm -r publish --dry-run",
    "publish:packages": "pnpm -r publish",
    "outdated": "pnpm outdated -r",
    "update:playwright": "pnpm install --save-dev -w @playwright/test@latest && pnpm exec playwright install --with-deps",
    "secrets:scan": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--branches --tags\"",
    "secrets:scan:all": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--branches --tags --full-history\"",
    "secrets:scan:all-refs": "GIT_CONFIG_COUNT=1 GIT_CONFIG_KEY_0=diff.renameLimit GIT_CONFIG_VALUE_0=3000 gitleaks detect --redact=100 --source . --log-opts=\"--all --full-history\""
  },
  "keywords": [
    "mcp",
    "curriculum",
    "oak",
    "sdk",
    "education",
    "ai",
    "model-context-protocol"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem#readme",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/coverage-v8": "^4.1.7",
    "dependency-cruiser": "^17.4.3",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "knip": "^6.15.0",
    "markdownlint-cli": "^0.48.0",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "supertest": "^7.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "turbo": "^2.9.16",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
