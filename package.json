{
  "name": "@oaknational/mcp-ecosystem",
  "version": "0.5.0",
  "private": true,
  "description": "MCP ecosystem - A collection of MCP servers and supporting frameworks and libraries",
  "type": "module",
  "scripts": {
    "type-gen": "turbo run --continue type-gen",
    "doc-gen": "turbo run --continue doc-gen",
    "build": "turbo run --continue build",
    "clean": "turbo run clean",
    "dev": "turbo run --continue dev",
    "lint": "turbo run --continue lint",
    "lint:clean": "rm -rf **/.eslintcache",
    "test": "turbo run --continue test",
    "mutate": "turbo run --continue mutate",
    "test:e2e": "turbo run --continue test:e2e",
    "test:ui": "turbo run --continue test:ui",
    "smoke:dev:stub": "turbo run smoke:dev:stub",
    "smoke:dev:live": "turbo run smoke:dev:live",
    "smoke:remote": "turbo run smoke:remote",
    "type-check": "turbo run --continue type-check",
    "format:root": "prettier --write --cache .",
    "format-check:root": "prettier --check .",
    "markdownlint:root": "markdownlint --fix .",
    "markdownlint-check:root": "markdownlint .",
    "make": "pnpm i && pnpm type-gen && pnpm build && pnpm type-check && pnpm doc-gen && pnpm markdownlint:root && pnpm lint -- --fix && pnpm format:root",
    "qg": "pnpm format-check:root && pnpm type-check && pnpm lint && pnpm markdownlint-check:root && pnpm test && pnpm test:ui && pnpm test:e2e && pnpm smoke:dev",
    "re-build": "pnpm clean && pnpm install && pnpm type-gen && pnpm build",
    "fix": "pnpm format:root && pnpm markdownlint:root && pnpm lint -- --fix ",
    "check": "pnpm clean && pnpm lint:clean && pnpm make && pnpm qg",
    "app:search": "pnpm run dev --filter=@oaknational/open-curriculum-semantic-search",
    "identity-check": "node scripts/identity-check.mjs --mode=enforce",
    "identity-report": "node scripts/identity-check.mjs --mode=report",
    "prepare": "husky",
    "publish:dry": "pnpm -r publish --dry-run",
    "publish:packages": "pnpm -r publish",
    "outdated": "pnpm outdated -r"
  },
  "keywords": [
    "mcp",
    "notion",
    "ai",
    "llm",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a",
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "axios": "^1.12.2"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.35.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@stryker-mutator/core": "^9.1.1",
    "@stryker-mutator/typescript-checker": "^9.1.1",
    "@stryker-mutator/vitest-runner": "^9.1.1",
    "@types/node": "^22",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitest/coverage-v8": "^3.2.4",
    "cloc": "2.6.0-cloc",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.1",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "markdownlint-cli": "^0.45.0",
    "pnpm": "^10.17.1",
    "prettier": "^3.6.2",
    "semantic-release": "^24.2.9",
    "supertest": "^7.1.4",
    "ts-morph": "^27.0.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "turbo": "^2.5.8",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.0",
    "vitest": "^3.2.4"
  }
}
