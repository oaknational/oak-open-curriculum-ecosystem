# Turbo cache
.turbo
tc-profile.json
lint-profile.json

# Built files
dist
**/dist

# Generated analysis output
dependency-graph.dot
dependency-graph.svg

# Agent Interactions
collaboration.txt

# Local MCP server config
.mcp.json

# Platform settings: project config is tracked, local overrides are not.
# Project settings define the agentic system contract (skill permissions,
# hooks, plugin state) and must work on fresh checkout.
# Local settings contain user-specific paths and one-off permissions.
.claude/settings.local.json
.cursor/settings.local.json
.gemini/settings.local.json

# Claude agent worktrees (transient, machine-local)
.claude/worktrees/

# Generated docs
**/docs/api
**/docs/api-md/index.md
**/.typedoc
**/_typedoc_*

# Type declarations
**/*.d.ts
**/*.d.ts.map

# File system artifacts
.DS_Store

# Generated SDK reference data (JSON maps from sitemap scan; regenerated on demand).
# See packages/sdks/oak-sdk-codegen/reference/README.md
packages/sdks/oak-sdk-codegen/reference/*.json

# Local reference files, not for source control
.agent/reference-local/**/*
!.agent/reference-local/.gitignore

# Runtime tactical track cards are *tracked*, not gitignored: multi-agent
# and multi-location collaboration on a track happens via git, the same
# coordination channel the rest of the repo uses. Single-writer-per-card
# still holds; multiple cards disambiguate multiple writers via the
# <workstream>--<agent>--<branch>.md naming convention.
# See .agent/memory/operational/tracks/README.md.

