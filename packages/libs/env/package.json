{
  "name": "@oaknational/mcp-env",
  "version": "0.0.0-development",
  "description": "Runtime-adaptive environment library for MCP applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist .turbo",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "mcp",
    "environment",
    "adaptive",
    "env",
    "config"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "packages/libs/env"
  }
}
