{
  "name": "@oaknational/env-resolution",
  "version": "0.0.0-development",
  "private": true,
  "description": "Environment resolution pipeline for MCP applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist .turbo",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@oaknational/result": "workspace:*",
    "dotenv": "^17.4.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "tsup": "^8.5.1",
    "typescript": "^6",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "24.x"
  },
  "keywords": [
    "mcp",
    "environment",
    "env",
    "config",
    "resolution",
    "dotenv",
    "zod"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git",
    "directory": "packages/libs/env-resolution"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem/tree/main/packages/libs/env-resolution#readme"
}
