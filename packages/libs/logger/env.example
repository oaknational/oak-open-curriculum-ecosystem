# Logger configuration defaults
#
# LOG_LEVEL controls verbosity. Valid values: TRACE, DEBUG, INFO, WARN, ERROR, FATAL
LOG_LEVEL=INFO

# Stdout sink (always true for browser/edge environments)
MCP_LOGGER_STDOUT=true

# Optional: enable file logging (Node.js runtimes only)
# MCP_LOGGER_FILE_PATH=./logs/app.log
# MCP_LOGGER_FILE_APPEND=true
