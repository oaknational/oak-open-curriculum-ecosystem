{
  "name": "@oaknational/mcp-storage",
  "version": "0.0.0-development",
  "description": "Adaptive storage library for multi-runtime MCP applications",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache .",
    "type-check": "tsc -p tsconfig.lint.json --noEmit"
  },
  "dependencies": {},
  "devDependencies": {
    "pnpm": "^10.17.0",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "packages/libs/storage"
  },
  "license": "MIT"
}
