{
  "name": "@oaknational/result",
  "version": "0.0.0-development",
  "description": "Result<T, E> type for explicit error handling without exceptions",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/**/*",
    "src/**/*",
    "!**/*.test.ts",
    "!**/*.integration.test.ts"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.39.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}

