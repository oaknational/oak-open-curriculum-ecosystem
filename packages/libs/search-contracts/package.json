{
  "name": "@oaknational/search-contracts",
  "version": "0.0.0-development",
  "private": true,
  "description": "Canonical semantic-search field inventory and stage contracts",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist .turbo",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@oaknational/sdk-codegen": "workspace:*",
    "@oaknational/type-helpers": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": "24.x"
  },
  "license": "MIT"
}
