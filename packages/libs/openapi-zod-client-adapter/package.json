{
  "name": "@oaknational/openapi-zod-client-adapter",
  "version": "0.0.0-development",
  "description": "Adapter for openapi-zod-client that enforces Zod v3/v4 boundary",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build-adapter": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint  .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "openapi-zod-client": "^1.18.3",
    "zod": "^3"
  },
  "peerDependencies": {
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "openapi3-ts": "^4.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "packages/libs/openapi-zod-client-adapter"
  },
  "keywords": [
    "openapi",
    "zod",
    "adapter",
    "code-generation"
  ],
  "license": "MIT"
}
