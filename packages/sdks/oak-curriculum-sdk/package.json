{
  "name": "@oaknational/oak-curriculum-sdk",
  "version": "0.0.1",
  "description": "TypeScript SDK for Oak National Academy Curriculum API",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "type-gen": "pnpm generate:types",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "pregenerate:types": "pnpm generate:clean",
    "generate:types": "pnpm generate:openapi && pnpm generate:zod",
    "generate:openapi": "tsx scripts/typegen.ts",
    "generate:zod": "tsx scripts/zodgen.ts",
    "generate:clean": "rm -rf src/types/generated",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint --cache .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "docs:api": "typedoc --options typedoc.json",
    "docs:api:html": "typedoc --options typedoc.ai.json",
    "docs:api:json": "typedoc --options typedoc.json --json docs/api/typedoc.json",
    "docs:api:json:ai": "typedoc --options typedoc.ai.json --json docs/api/typedoc.json",
    "docs:ai": "pnpm -s docs:api:json:ai && tsx scripts/generate-ai-doc.ts",
    "docs:api:md": "tsx scripts/generate-markdown-docs.ts",
    "docs:verify": "tsx scripts/verify-docs.ts",
    "docs:all": "pnpm -s docs:api:html && pnpm -s docs:ai && pnpm -s docs:api:md && pnpm -s docs:verify"
  },
  "dependencies": {
    "openapi-fetch": "^0.14.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.3",
    "@types/node": "^22.10.5",
    "dotenv": "^17.2.1",
    "openapi-typescript": "^7.9.1",
    "openapi-zod-client": "^1.18.3",
    "openapi3-ts": "^4.5.0",
    "typedoc": "^0.26.5",
    "typedoc-plugin-markdown": "^4.2.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "packages/oak-curriculum-sdk"
  },
  "keywords": [
    "oak",
    "curriculum",
    "api",
    "sdk",
    "education",
    "typescript"
  ],
  "author": "Oak National Academy",
  "license": "MIT"
}
