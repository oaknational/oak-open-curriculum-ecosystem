{
  "name": "@oaknational/curriculum-sdk",
  "version": "1.6.1",
  "description": "TypeScript SDK for Oak National Academy Curriculum API",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.integration.test.ts",
    "!src/**/*.bak",
    "README.md",
    "LICENCE"
  ],
  "engines": {
    "node": "24.x"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "development": "./src/client/index.ts",
      "default": "./dist/client/index.js"
    },
    "./client/*": {
      "types": "./dist/client/*.d.ts",
      "development": "./src/client/*.ts",
      "default": "./dist/client/*.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "development": "./src/config/index.ts",
      "default": "./dist/config/index.js"
    },
    "./config/*": {
      "types": "./dist/config/*.d.ts",
      "development": "./src/config/*.ts",
      "default": "./dist/config/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "development": "./src/types/index.ts",
      "default": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "development": "./src/types/*.ts",
      "default": "./dist/types/*.js"
    },
    "./mcp": {
      "types": "./dist/mcp/execute-tool-call.d.ts",
      "development": "./src/mcp/execute-tool-call.ts",
      "default": "./dist/mcp/execute-tool-call.js"
    },
    "./mcp/*": {
      "types": "./dist/mcp/*.d.ts",
      "development": "./src/mcp/*.ts",
      "default": "./dist/mcp/*.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "development": "./src/validation/index.ts",
      "default": "./dist/validation/index.js"
    },
    "./validation/*": {
      "types": "./dist/validation/*.d.ts",
      "development": "./src/validation/*.ts",
      "default": "./dist/validation/*.js"
    },
    "./public/search": {
      "types": "./dist/public/search.d.ts",
      "development": "./src/public/search.ts",
      "default": "./dist/public/search.js"
    },
    "./public/search.js": {
      "types": "./dist/public/search.d.ts",
      "development": "./src/public/search.ts",
      "default": "./dist/public/search.js"
    },
    "./public/mcp-tools": {
      "types": "./dist/public/mcp-tools.d.ts",
      "development": "./src/public/mcp-tools.ts",
      "default": "./dist/public/mcp-tools.js"
    },
    "./public/mcp-tools.js": {
      "types": "./dist/public/mcp-tools.d.ts",
      "development": "./src/public/mcp-tools.ts",
      "default": "./dist/public/mcp-tools.js"
    },
    "./elasticsearch": {
      "types": "./dist/elasticsearch.d.ts",
      "development": "./src/elasticsearch.ts",
      "default": "./dist/elasticsearch.js"
    },
    "./elasticsearch.js": {
      "types": "./dist/elasticsearch.d.ts",
      "development": "./src/elasticsearch.ts",
      "default": "./dist/elasticsearch.js"
    }
  },
  "scripts": {
    "prepublishOnly": "cp ../../../LICENCE ./LICENCE",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "docs:api": "typedoc --options typedoc.json --skipErrorChecking",
    "docs:api:html": "typedoc --options typedoc.ai.json --skipErrorChecking",
    "docs:api:json": "typedoc --options typedoc.json --json docs/api/typedoc.json --skipErrorChecking",
    "docs:api:json:ai": "typedoc --options typedoc.ai.json --json docs/api/typedoc.json --skipErrorChecking",
    "docs:mcp": "typedoc --options typedoc.mcp.json --skipErrorChecking"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": "^9.3.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@oaknational/logger": "workspace:*",
    "@oaknational/result": "workspace:*",
    "@oaknational/sdk-codegen": "workspace:*",
    "@oaknational/type-helpers": "workspace:*",
    "@zod/core": "^0.11.6",
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6",
    "vitest": "^4.1.3"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git",
    "directory": "packages/sdks/oak-curriculum-sdk"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem/tree/main/packages/sdks/oak-curriculum-sdk#readme",
  "keywords": [
    "oak",
    "curriculum",
    "api",
    "sdk",
    "education",
    "typescript"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
