{
  "name": "@oaknational/curriculum-sdk",
  "version": "0.8.0",
  "description": "TypeScript SDK for Oak National Academy Curriculum API",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "24.x"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client/*": {
      "types": "./dist/client/*.d.ts",
      "default": "./dist/client/*.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./config/*": {
      "types": "./dist/config/*.d.ts",
      "default": "./dist/config/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "./mcp": {
      "types": "./dist/mcp/execute-tool-call.d.ts",
      "default": "./dist/mcp/execute-tool-call.js"
    },
    "./mcp/*": {
      "types": "./dist/mcp/*.d.ts",
      "default": "./dist/mcp/*.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    },
    "./validation/*": {
      "types": "./dist/validation/*.d.ts",
      "default": "./dist/validation/*.js"
    },
    "./public/search": {
      "types": "./dist/public/search.d.ts",
      "default": "./dist/public/search.js"
    },
    "./public/search.js": {
      "types": "./dist/public/search.d.ts",
      "default": "./dist/public/search.js"
    },
    "./public/mcp-tools": {
      "types": "./dist/public/mcp-tools.d.ts",
      "default": "./dist/public/mcp-tools.js"
    },
    "./public/mcp-tools.js": {
      "types": "./dist/public/mcp-tools.d.ts",
      "default": "./dist/public/mcp-tools.js"
    },
    "./public/bulk": {
      "types": "./dist/public/bulk.d.ts",
      "default": "./dist/public/bulk.js"
    },
    "./public/bulk.js": {
      "types": "./dist/public/bulk.d.ts",
      "default": "./dist/public/bulk.js"
    },
    "./elasticsearch": {
      "types": "./dist/elasticsearch.d.ts",
      "default": "./dist/elasticsearch.js"
    },
    "./elasticsearch.js": {
      "types": "./dist/elasticsearch.d.ts",
      "default": "./dist/elasticsearch.js"
    }
  },
  "scripts": {
    "prepublishOnly": "cp ../../../LICENSE ./LICENSE",
    "type-gen": "pnpm generate:types",
    "posttype-gen": "pnpm -w format:root",
    "vocab-gen": "tsx vocab-gen/run-vocab-gen.ts",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo src/types/generated",
    "pregenerate:types": "pnpm generate:clean",
    "generate:types": "pnpm generate:openapi && pnpm generate:zod && pnpm generate:bulk",
    "generate:openapi": "tsx type-gen/typegen.ts",
    "generate:zod": "tsx type-gen/zodgen.ts",
    "generate:bulk": "tsx type-gen/bulkgen.ts",
    "generate:clean": "rm -rf src/types/generated",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "docs:api": "typedoc --options typedoc.json --skipErrorChecking",
    "docs:api:html": "typedoc --options typedoc.ai.json --skipErrorChecking",
    "docs:api:json": "typedoc --options typedoc.json --json docs/api/typedoc.json --skipErrorChecking",
    "docs:api:json:ai": "typedoc --options typedoc.ai.json --json docs/api/typedoc.json --skipErrorChecking",
    "docs:mcp": "typedoc --options typedoc.mcp.json --skipErrorChecking",
    "docs:ai": "pnpm -s docs:api:json:ai && tsx type-gen/generate-ai-doc.ts",
    "docs:api:md": "tsx type-gen/generate-markdown-docs.ts",
    "docs:verify": "tsx type-gen/verify-docs.ts",
    "doc-gen": "pnpm -s docs:api:html && pnpm -s docs:ai && pnpm -s docs:api:md && pnpm -s docs:verify"
  },
  "dependencies": {
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/openapi-zod-client-adapter": "workspace:*",
    "@oaknational/result": "workspace:*",
    "@zod/core": "^0.11.6",
    "openapi-fetch": "^0.15.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^9.3.2",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^24.10.13",
    "dotenv": "^17.3.1",
    "openapi-typescript": "^7.10.1",
    "openapi3-ts": "^4.5.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "packages/sdks/oak-curriculum-sdk"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-mcp-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-mcp-ecosystem/tree/main/packages/sdks/oak-curriculum-sdk#readme",
  "keywords": [
    "oak",
    "curriculum",
    "api",
    "sdk",
    "education",
    "typescript"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
