{
  "name": "@oaknational/oak-curriculum-sdk",
  "version": "0.0.0-development",
  "description": "TypeScript SDK for Oak National Academy Curriculum API",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./client/*": {
      "types": "./dist/client/*.d.ts",
      "default": "./dist/client/*.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    },
    "./config/*": {
      "types": "./dist/config/*.d.ts",
      "default": "./dist/config/*.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    },
    "./types/*": {
      "types": "./dist/types/*.d.ts",
      "default": "./dist/types/*.js"
    },
    "./mcp": {
      "types": "./dist/mcp/execute-tool-call.d.ts",
      "default": "./dist/mcp/execute-tool-call.js"
    },
    "./mcp/*": {
      "types": "./dist/mcp/*.d.ts",
      "default": "./dist/mcp/*.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "default": "./dist/validation/index.js"
    },
    "./validation/*": {
      "types": "./dist/validation/*.d.ts",
      "default": "./dist/validation/*.js"
    }
  },
  "scripts": {
    "type-gen": "pnpm generate:types",
    "posttype-gen": "pnpm -w format:root",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo src/types/generated",
    "pregenerate:types": "pnpm generate:clean",
    "generate:types": "pnpm generate:openapi && pnpm generate:zod",
    "generate:openapi": "tsx type-gen/typegen.ts",
    "generate:zod": "tsx type-gen/zodgen.ts",
    "generate:clean": "rm -rf src/types/generated",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint  .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "docs:prepare": "tsx type-gen/sanitize-docs.ts",
    "docs:api": "pnpm -s docs:prepare && typedoc --options typedoc.json --skipErrorChecking",
    "docs:api:html": "pnpm -s docs:prepare && typedoc --options typedoc.ai.json --skipErrorChecking",
    "docs:api:json": "pnpm -s docs:prepare && typedoc --options typedoc.json --json docs/api/typedoc.json --skipErrorChecking",
    "docs:api:json:ai": "pnpm -s docs:prepare && typedoc --options typedoc.ai.json --json docs/api/typedoc.json --skipErrorChecking",
    "docs:mcp": "pnpm -s docs:prepare && typedoc --options typedoc.mcp.json --skipErrorChecking",
    "docs:ai": "pnpm -s docs:api:json:ai && tsx type-gen/generate-ai-doc.ts",
    "docs:api:md": "tsx type-gen/generate-markdown-docs.ts",
    "docs:verify": "tsx type-gen/verify-docs.ts",
    "doc-gen": "pnpm -s docs:api:html && pnpm -s docs:ai && pnpm -s docs:api:md && pnpm -s docs:verify"
  },
  "dependencies": {
    "@oaknational/mcp-logger": "workspace:*",
    "openapi-fetch": "^0.15.0",
    "zod": "^3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.20.1",
    "@next/eslint-plugin-next": "^15.5.3",
    "@types/node": "^22.10.5",
    "dotenv": "^17.2.1",
    "openapi-typescript": "^7.10.1",
    "openapi-zod-client": "^1.18.3",
    "openapi3-ts": "^4.5.0",
    "tsx": "^4.20.5",
    "typedoc": "^0.28.12",
    "typedoc-plugin-markdown": "^4.8.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "packages/oak-curriculum-sdk"
  },
  "keywords": [
    "oak",
    "curriculum",
    "api",
    "sdk",
    "education",
    "typescript"
  ],
  "author": "Oak National Academy",
  "license": "MIT"
}
