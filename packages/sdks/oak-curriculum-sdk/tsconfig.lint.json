{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "*.config.ts",
    "vocab-gen/**/*.ts",
    "bin/**/*.ts",
    "e2e-tests/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "test-cache", "e2e-tests/scripts/**", "docs/_typedoc_src/**"]
}
