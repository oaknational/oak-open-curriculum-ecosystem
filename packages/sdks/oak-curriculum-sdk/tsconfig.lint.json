{
  "extends": "../../../tsconfig.lint.root.json",
  "compilerOptions": {
    "tsBuildInfoFile": ".tsbuildinfo.lint"
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "*.config.ts",
    "scripts/**/*.ts",
    "bin/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
