import type { OakApiPathBasedClient } from '../client/index';

const operationIDToToolName = {
  'getLessonTranscript-getLessonTranscript': {
    toolName: 'oak-get-lessons-transcript',
    operationIdKey: 'getLessonTranscript-getLessonTranscript',
  },
  // and all the rest
} as const;

type AllOperationIds = keyof typeof operationIDToToolName;
type AllToolNames = (typeof operationIDToToolName)[AllOperationIds]['toolName'];

// I feel like this contraint is useful, but I'm not sure how to apply it
interface ToolNameForOperationId<OperationId extends AllOperationIds> {
  toolName: AllToolNames;
  operationIdKey: OperationId;
}

function isOperationId(operationId: string): operationId is AllOperationIds {
  const stringOperationId: string = operationId;
  return Object.keys(operationIDToToolName).includes(stringOperationId);
}

export function getToolNameFromOperationId(operationId: AllOperationIds): AllToolNames {
  if (!isOperationId(operationId)) {
    throw new TypeError(
      `Invalid operation ID: ${operationId}. Allowed values: ${Object.keys(operationIDToToolName).join(', ')}`,
    );
  }
  return operationIDToToolName[operationId].toolName;
}

export const mcpTools = {
  'oak-get-lessons-transcript': {
    name: 'oak-get-lessons-transcript',
    path: '/lessons/{lesson}/transcript',
    method: 'GET',
    pathParams: { lesson: { typePrimitive: 'string', valueConstraint: false } },
    queryParams: {},
    executor: (
      client: OakApiPathBasedClient,
      requestParams: { params: { path: { lesson: string } } },
    ) => {
      const lessonPathParam = requestParams.params.path.lesson;
      // The allowed value for lesson is any string, so we don't need a type guard for it.

      return client['/lessons/{lesson}/transcript']['GET']({
        params: {
          path: {
            lesson: lessonPathParam,
          },
        },
      });
    },
  },
  // and the rest
} as const;

type ToolsMap = typeof mcpTools;

export function getToolFromToolName<ToolName extends AllToolNames>(
  toolName: ToolName,
): ToolsMap[ToolName] {
  return mcpTools[toolName];
}

export function getToolFromOperationId(operationId: AllOperationIds): ToolsMap[AllToolNames] {
  return mcpTools[getToolNameFromOperationId(operationId)];
}
