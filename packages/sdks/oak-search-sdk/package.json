{
  "name": "@oaknational/oak-search-sdk",
  "version": "0.0.0-development",
  "description": "TypeScript SDK for Oak semantic search — retrieval, admin, and observability services",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "24.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@oaknational/mcp-logger": "workspace:*",
    "@oaknational/result": "workspace:*"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": "^9.2.0",
    "@oaknational/oak-curriculum-sdk": "workspace:*"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^9.2.0",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@oaknational/oak-curriculum-sdk": "workspace:*",
    "@types/node": "^24",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/oaknational/oak-mcp-ecosystem.git",
    "directory": "packages/sdks/oak-search-sdk"
  },
  "keywords": [
    "oak",
    "search",
    "semantic",
    "elasticsearch",
    "sdk",
    "education",
    "typescript"
  ],
  "author": "Oak National Academy",
  "license": "MIT"
}
