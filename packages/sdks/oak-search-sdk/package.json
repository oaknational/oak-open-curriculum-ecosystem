{
  "name": "@oaknational/oak-search-sdk",
  "version": "0.0.0-development",
  "private": true,
  "description": "TypeScript SDK for Oak semantic search — retrieval, admin, and observability services",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": "24.x"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./read": {
      "types": "./dist/read.d.ts",
      "default": "./dist/read.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "default": "./dist/admin.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@oaknational/logger": "workspace:*",
    "@oaknational/result": "workspace:*",
    "@oaknational/sdk-codegen": "workspace:*",
    "@oaknational/search-contracts": "workspace:*",
    "@oaknational/type-helpers": "workspace:*"
  },
  "peerDependencies": {
    "@elastic/elasticsearch": "^9.3.4"
  },
  "devDependencies": {
    "@elastic/elasticsearch": "^9.3.4",
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5",
    "vitest": "^4.1.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git",
    "directory": "packages/sdks/oak-search-sdk"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem/tree/main/packages/sdks/oak-search-sdk#readme",
  "keywords": [
    "oak",
    "search",
    "semantic",
    "elasticsearch",
    "sdk",
    "education",
    "typescript"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
