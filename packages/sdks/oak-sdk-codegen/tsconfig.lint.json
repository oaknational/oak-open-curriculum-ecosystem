{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "code-generation/**/*.ts",
    "vocab-gen/**/*.ts",
    "docs/**/*.ts",
    "e2e-tests/**/*.ts",
    "**/*.test.ts",
    "**/*.spec.ts",
    "*.config.ts"
  ],
  "exclude": ["node_modules", "dist", "test-cache"]
}
