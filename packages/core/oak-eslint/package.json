{
  "name": "@oaknational/eslint-plugin-standards",
  "version": "1.0.0",
  "private": true,
  "description": "Custom ESLint rules for architectural boundary enforcement and code standards",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": "^6"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@typescript-eslint/utils": "^8.60.0",
    "@vitest/eslint-plugin": "^1.6.18",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "minimatch": "^10.2.5",
    "typescript-eslint": "^8.60.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@typescript-eslint/rule-tester": "^8.60.0",
    "eslint": "^10.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "clean": "rm -rf dist .turbo",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "vitest run",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "validate-boundaries": "cd ../../.. && pnpm exec tsx packages/core/oak-eslint/scripts/validate-boundaries.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-curriculum-ecosystem.git",
    "directory": "packages/core/oak-eslint"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-curriculum-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-curriculum-ecosystem/tree/main/packages/core/oak-eslint#readme",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "oak",
    "architecture",
    "boundaries"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
