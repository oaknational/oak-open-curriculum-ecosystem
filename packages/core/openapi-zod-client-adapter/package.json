{
  "name": "@oaknational/openapi-zod-client-adapter",
  "version": "0.0.0-development",
  "private": true,
  "description": "Adapter for openapi-zod-client that enforces Zod v3/v4 boundary",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "openapi-zod-client": "^1.18.3",
    "zod": "^3"
  },
  "peerDependencies": {
    "openapi3-ts": "^4.5.0"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "openapi3-ts": "^4.5.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": "24.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oaknational/oak-open-data-ecosystem.git",
    "directory": "packages/core/openapi-zod-client-adapter"
  },
  "bugs": {
    "url": "https://github.com/oaknational/oak-open-data-ecosystem/issues"
  },
  "homepage": "https://github.com/oaknational/oak-open-data-ecosystem/tree/main/packages/core/openapi-zod-client-adapter#readme",
  "keywords": [
    "openapi",
    "zod",
    "adapter",
    "code-generation"
  ],
  "author": {
    "name": "Jim Cresswell",
    "email": "contact@jimcresswell.net",
    "url": "https://jimcresswell.net"
  },
  "contributors": [
    {
      "name": "Oak National Academy",
      "email": "help@thenational.academy",
      "url": "https://www.thenational.academy"
    }
  ],
  "license": "MIT"
}
