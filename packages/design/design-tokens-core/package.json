{
  "name": "@oaknational/design-tokens-core",
  "version": "0.0.0-development",
  "private": true,
  "description": "Pure helpers for validating DTCG token tiers and emitting Oak CSS custom properties",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist .turbo",
    "build": "tsup && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@oaknational/result": "workspace:*"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.6.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": "24.x"
  }
}
