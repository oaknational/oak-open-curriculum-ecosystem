    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@oaknational/design-tokens-core": "workspace:*"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
