{
  "name": "@oaknational/oak-design-tokens",
  "version": "0.0.0-development",
  "private": true,
  "description": "Oak token source files and generated CSS custom properties",
  "type": "module",
  "exports": {
    "./index.css": "./dist/index.css",
    "./terminal-theme": {
      "types": "./dist/terminal-theme.d.ts",
      "development": "./src/terminal-theme.ts",
      "import": "./dist/terminal-theme.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist .turbo",
    "build": "pnpm exec tsx src/build.ts && pnpm exec tsup src/terminal-theme.ts --format esm --out-dir dist && pnpm exec tsc --emitDeclarationOnly --project tsconfig.build.json",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@oaknational/design-tokens-core": "workspace:*",
    "@oaknational/result": "workspace:*"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": "24.x"
  }
}
