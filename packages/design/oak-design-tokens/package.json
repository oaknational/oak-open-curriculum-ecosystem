{
  "name": "@oaknational/oak-design-tokens",
  "version": "0.0.0-development",
  "private": true,
  "description": "Oak token source files and generated CSS custom properties",
  "type": "module",
  "exports": {
    "./index.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "clean": "rm -rf dist .turbo",
    "build": "pnpm exec tsx src/build.ts",
    "type-check": "tsc -p tsconfig.lint.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "lint:fix": "eslint --fix ."
  },
  "dependencies": {
    "@oaknational/design-tokens-core": "workspace:*",
    "@oaknational/result": "workspace:*"
  },
  "devDependencies": {
    "@oaknational/eslint-plugin-standards": "workspace:*",
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "typescript": "^6",
    "vitest": "^4.1.3"
  },
  "engines": {
    "node": "24.x"
  }
}
