    "line-height-300": { "$type": "number", "$value": "1.4" },
    "line-height-400": { "$type": "number", "$value": "1.6" },
    "line-height-700": { "$type": "number", "$value": "1.1" }
  },
  "space": {
    "200": { "$type": "dimension", "$value": "0.5rem" },
    "300": { "$type": "dimension", "$value": "0.75rem" },
    "400": { "$type": "dimension", "$value": "1rem" },
    "500": { "$type": "dimension", "$value": "1.5rem" },
    "700": { "$type": "dimension", "$value": "2.5rem" }
  },
  "radius": {
    "md": { "$type": "dimension", "$value": "0.9rem" },
    "lg": { "$type": "dimension", "$value": "1.4rem" },
    "pill": { "$type": "dimension", "$value": "999px" }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": "0 24px 50px rgba(16, 32, 51, 0.12)"
    }
  }
