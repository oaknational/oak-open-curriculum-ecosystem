{
  "color": {
    "ink-950": { "$type": "color", "$value": "#102033" },
    "ink-800": { "$type": "color", "$value": "#31465f" },
    "ink-700": { "$type": "color", "$value": "#485d75" },
    "paper-050": { "$type": "color", "$value": "#fcfbf8" },
    "paper-100": { "$type": "color", "$value": "#f4efe8" },
    "paper-200": { "$type": "color", "$value": "#e6ddd2" },
    "fern-500": { "$type": "color", "$value": "#1d6f5f" },
    "fern-600": { "$type": "color", "$value": "#15574b" },
    "sun-300": { "$type": "color", "$value": "#f0c974" },
