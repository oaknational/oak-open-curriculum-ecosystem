    "sky-400": { "$type": "color", "$value": "#8ab6d6" },
    "danger-500": { "$type": "color", "$value": "#b43c31" }
  },
  "font": {
    "family-body": {
      "$type": "fontFamily",
      "$value": "\"Source Sans 3\", \"Segoe UI\", sans-serif"
    },
    "family-display": {
      "$type": "fontFamily",
      "$value": "\"Fraunces\", Georgia, serif"
    },
    "size-200": { "$type": "dimension", "$value": "0.875rem" },
