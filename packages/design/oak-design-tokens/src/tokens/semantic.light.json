    "gap-md": {
      "$type": "dimension",
      "$value": "{space.300}"
    },
    "gap-lg": {
      "$type": "dimension",
      "$value": "{space.500}"
    },
    "shell-padding": {
      "$type": "dimension",
      "$value": "{space.700}"
    },
    "shell-padding-mobile": {
      "$type": "dimension",
      "$value": "{space.500}"
    },
    "control-padding-inline": {
      "$type": "dimension",
      "$value": "{space.400}"
    },
    "control-padding-block": {
      "$type": "dimension",
      "$value": "{space.300}"
    },
    "radius-panel": {
      "$type": "dimension",
      "$value": "{radius.lg}"
    },
    "radius-control": {
      "$type": "dimension",
      "$value": "{radius.md}"
    },
    "radius-pill": {
      "$type": "dimension",
      "$value": "{radius.pill}"
    },
