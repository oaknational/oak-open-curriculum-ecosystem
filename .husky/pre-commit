#!/usr/bin/env sh

# Disable turbo TUI
export TURBO_UI=0

echo "🔍 Running pre-commit checks..."

echo "📝 Checking formatting on staged files..."
if ! pnpm agent-tools:repo-check prettier-staged; then
  echo "❌ Formatting issues found!"
  echo "💡 Run 'pnpm format:root' to fix formatting issues, then stage the changes"
  exit 1
fi

echo "🔍 Running markdownlint on staged Markdown files..."
if ! pnpm agent-tools:repo-check markdownlint-staged; then
  echo "❌ Markdownlint issues found!"
  echo "💡 Run 'pnpm markdownlint:root' to fix markdown issues, then stage the changes"
  exit 1
fi

echo "🧭 Running workspace-owned repo validators..."
if ! pnpm repo-validators:check; then
  echo "❌ Repo validator checks failed!"
  exit 1
fi

echo "🐚 Linting shell scripts..."
if ! pnpm lint:shell; then
  echo "❌ Shell lint failed!"
  exit 1
fi

echo "🧪 Running build, type-check, lint, and unit tests..."
if ! pnpm turbo run --continue --output-logs=errors-only build type-check lint test; then
  echo "❌ Build, type-check, lint, or unit tests failed!"
  exit 1
fi

echo "✅ Pre-commit checks completed!"
