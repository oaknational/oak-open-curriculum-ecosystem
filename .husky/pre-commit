#!/usr/bin/env sh

# Disable turbo TUI
export TURBO_UI=0

echo "🔍 Running pre-commit checks..."

# Run lint-staged for formatting only
echo "📝 Checking formatting..."
if ! pnpm format-check:root; then
  echo "❌ Formatting issues found!"
  echo "💡 Run 'pnpm format:root' to fix formatting issues, then commit the changes"
  exit 1
fi

echo "🔤 Running type checks..."
pnpm type-check

echo "🔍 Running lint for changed files..."
pnpm lint

# Run full markdownlint
echo "🔍 Running full markdownlint..."
pnpm markdownlint-check:root

# This may not find any relevant tests, that is fine.
echo "🧪 Running tests on changed files..."
pnpm test

echo "✅ Pre-commit checks completed!"

