#!/usr/bin/env sh

# Disable turbo TUI
export TURBO_UI=0

# Limit concurrency to reduce resource contention and timeout failures
export TURBO_CONCURRENCY=4

echo "🚀 Running pre-push checks..."

echo "📝 Checking formatting..."
if ! pnpm format-check:root; then
  echo "❌ Formatting issues found!"
  echo "💡 Run 'pnpm format:root' to fix formatting issues, then commit the changes"
  exit 1
fi

echo "🔍 Running full markdownlint..."
pnpm markdownlint-check:root

echo "🔤 Running build and verification..."
pnpm turbo run type-gen build type-check lint test

echo "🧪 Running E2E tests..."
pnpm turbo run test:e2e --only

echo "✅ Pre-push checks completed!"

