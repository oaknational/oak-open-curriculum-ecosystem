#!/usr/bin/env sh

# Disable turbo TUI
export TURBO_UI=0


echo "🚀 Running pre-push checks..."

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "❌ gitleaks is not installed."
  echo "Install it before running pre-push:"
  echo "  - macOS: brew install gitleaks"
  echo "  - Go: go install github.com/gitleaks/gitleaks/v8@latest"
  echo "Then retry your push."
  exit 1
fi

echo "🛡️ Running secret scan..."
if ! pnpm secrets:scan; then
  echo "❌ Secret scan failed."
  echo "Remove or scrub secret-like values before pushing."
  echo "Use local placeholders for .env.example and real credentials only in .env files."
  exit 1
fi

echo "📝 Checking formatting..."
if ! pnpm format-check:root; then
  echo "❌ Formatting issues found!"
  echo "💡 Run 'pnpm format:root' to fix formatting issues, then commit the changes"
  exit 1
fi

echo "🔍 Running full markdownlint..."
if ! pnpm markdownlint-check:root; then
  echo "❌ Markdownlint issues found!"
  echo "💡 Run 'pnpm markdownlint:root' to fix markdown issues, then commit again"
  exit 1
fi

echo "🔧 Validating sub-agents..."
if ! pnpm subagents:check; then
  echo "❌ Sub-agent validation failed!"
  exit 1
fi

echo "🔧 Validating portability..."
if ! pnpm portability:check; then
  echo "❌ Portability validation failed!"
  exit 1
fi

echo "🔬 Running knip (unused code detection)..."
if ! pnpm knip; then
  echo "❌ Knip found unused code, exports, or dependencies!"
  echo "💡 Run 'pnpm knip' to see details, then fix or remove unused items"
  exit 1
fi

echo "🔗 Running depcruise (circular deps, orphans, layer violations)..."
if ! pnpm depcruise; then
  echo "❌ Dependency-cruiser found violations!"
  echo "💡 Run 'pnpm depcruise' to see details, then fix circular dependencies or orphan modules"
  exit 1
fi

echo "🧪 Running root-level script tests..."
if ! pnpm test:root-scripts; then
  echo "❌ Root-level script tests failed!"
  exit 1
fi

echo "🔤 Running build, type-check, lint, and tests..."
pnpm turbo run sdk-codegen build type-check lint test test:e2e test:ui smoke:dev:stub

echo "✅ Pre-push checks completed!"
